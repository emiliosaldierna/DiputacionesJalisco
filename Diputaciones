  }

  // === COMPARACIÓN FEDERAL VS LOCAL ===
  function renderCompareFedLocal() {
    const DF_OBJ = [3,4,6,7,9,10,11,12,13,14,16,20];
    
    // Calcular % del bloque1 en Diputado FEDERAL 2024 vs Diputado LOCAL 2024
    // Para calcular el voto federal usaremos los mismos bloques pero en la elección de DipL2024
    // (no tenemos DipF2024 por sección — usamos DipL como proxy más cercano)
    // Y para la "fuerza federal" usamos pres24 si existe, si no gob24
    
    function pctEnEleccion(df, elecKey, blockId) {
      if (!elecKey || !ELEC_OFFSET_MAP[elecKey]) return null;
      const pool = DATA.filter(function(d){return d[2] === df;});
      let totalVV = 0, blockV = 0;
      pool.forEach(function(d){
        const e = getElec(d, elecKey); if (!e) return;
        totalVV += e.vv;
        blockV += blockTotal(d, elecKey, blocks[blockId]);
      });
      return totalVV > 0 ? blockV/totalVV*100 : 0;
    }
    
    // Comparación directa: Diputado FEDERAL 2024 vs Diputado LOCAL 2024 (mismas boletas, distinto sistema)
    const fedKey = 'f24';
    const locKey = 'd24';
    
    // Resumen general
    const DF_OBJ_ALL = DF_OBJ;
    let fedAvg = 0, locAvg = 0;
    let fedWinsB1 = 0, locWinsB1 = 0;
    
    const rows = DF_OBJ_ALL.map(function(df){
      const fedPct = pctEnEleccion(df, fedKey, 1);
      const locPct = pctEnEleccion(df, locKey, 1);
      const fedWin = DF_WIN[df] || DF_WIN[String(df)];
      const locWin = DL_WIN[df] || DL_WIN[String(df)];
      fedAvg += fedPct;
      locAvg += locPct;
      // Verificar si gana B1 (revisar bloque 1 vs todos los demás)
      const poolDF = DATA.filter(function(d){return d[2] === df;});
      let totals = [0,0,0,0]; // VV, B1, B2, B3
      poolDF.forEach(function(d){
        const eF = getElec(d, fedKey); if (eF) {
          totals[0] += eF.vv;
          totals[1] += blockTotal(d, fedKey, blocks[1]);
          totals[2] += blockTotal(d, fedKey, blocks[2]);
          totals[3] += blockTotal(d, fedKey, blocks[3]);
        }
      });
      if (totals[1] > totals[2] && totals[1] > totals[3]) fedWinsB1++;
      let locTotals = [0,0,0,0];
      poolDF.forEach(function(d){
        const eL = getElec(d, locKey); if (eL) {
          locTotals[0] += eL.vv;
          locTotals[1] += blockTotal(d, locKey, blocks[1]);
          locTotals[2] += blockTotal(d, locKey, blocks[2]);
          locTotals[3] += blockTotal(d, locKey, blocks[3]);
        }
      });
      if (locTotals[1] > locTotals[2] && locTotals[1] > locTotals[3]) locWinsB1++;
      return {df:df, fedPct:fedPct, locPct:locPct, fedWin:fedWin, locWin:locWin};
    });
    
    fedAvg /= DF_OBJ_ALL.length;
    locAvg /= DF_OBJ_ALL.length;
    const brecha = fedAvg - locAvg;
    
    // Cards de resumen
    let summary = '';
    summary += '<div class="cs-card">' +
      '<div class="cs-label">Federal · Bloque 1 promedio</div>' +
      '<div class="cs-value fed">' + fedAvg.toFixed(1) + '%</div>' +
      '<div class="cs-detail">' + fedWinsB1 + ' de 12 distritos ganados (DipF 2024)</div>' +
      '</div>';
    summary += '<div class="cs-card">' +
      '<div class="cs-label">Local · Bloque 1 promedio</div>' +
      '<div class="cs-value loc">' + locAvg.toFixed(1) + '%</div>' +
      '<div class="cs-detail">' + locWinsB1 + ' de 12 distritos ganados (DipL 2024)</div>' +
      '</div>';
    const sign = brecha > 0 ? '+' : '';
    summary += '<div class="cs-card">' +
      '<div class="cs-label">Brecha Fed - Local</div>' +
      '<div class="cs-value delta">' + sign + brecha.toFixed(1) + 'pp</div>' +
      '<div class="cs-detail">' + (brecha > 0 ? 'Voto federal arrastra al local' : 'Local supera al federal') + '</div>' +
      '</div>';
    $('compare-summary').innerHTML = summary;
    
    // Tabla detallada
    let grid = '';
    grid += '<div class="compare-header">D</div>';
    grid += '<div class="compare-header fed">🇲🇽 Diputado(a) FEDERAL 2024<br><span style="font-size:8px;color:var(--text-tri);font-weight:600">Cámara de Diputados</span></div>';
    grid += '<div class="compare-header loc">🏛️ Diputado(a) LOCAL 2024<br><span style="font-size:8px;color:var(--text-tri);font-weight:600">Congreso Jalisco</span></div>';
    grid += '<div class="compare-header diff">% Bloque 1<br><span style="font-size:8px;color:var(--text-tri);font-weight:600">Fed → Local · brecha</span></div>';
    
    rows.forEach(function(r){
      grid += '<div class="compare-row-id" data-df="' + r.df + '" title="Click para drill-down">D' + r.df + '</div>';
      // Federal
      let fedCell = '<span style="color:var(--text-tri);font-size:11px">Sin datos</span>';
      if (r.fedWin) {
        const c = PARTY_COLORS[r.fedWin.partido] || '#5a6b8a';
        fedCell = '<span class="compare-winner-name" title="' + r.fedWin.nombre + '">' + r.fedWin.nombre + '</span>' +
          '<span class="compare-winner-party" style="background:' + c + '22;color:' + c + ';border:1px solid ' + c + '">' + r.fedWin.partido + '</span>';
      }
      grid += '<div class="compare-cell">' + fedCell + '</div>';
      // Local
      let locCell = '<span style="color:var(--text-tri);font-size:11px">Sin datos</span>';
      if (r.locWin) {
        const c = PARTY_COLORS[r.locWin.partido] || '#5a6b8a';
        locCell = '<span class="compare-winner-name" title="' + r.locWin.nombre + '">' + r.locWin.nombre + '</span>' +
          '<span class="compare-winner-party" style="background:' + c + '22;color:' + c + ';border:1px solid ' + c + '">' + r.locWin.partido + '</span>';
      }
      grid += '<div class="compare-cell">' + locCell + '</div>';
      // Brecha
      const dFed = r.fedPct.toFixed(1);
      const dLoc = r.locPct.toFixed(1);
      const dGap = r.fedPct - r.locPct;
      const gapColor = dGap > 5 ? 'var(--red)' : (dGap > 0 ? 'var(--gold)' : 'var(--green)');
      const gapSign = dGap > 0 ? '+' : '';
      grid += '<div class="compare-cell">' +
        '<div style="display:flex;justify-content:space-between;align-items:center;gap:6px">' +
        '<span style="color:var(--gold);font-weight:700">' + dFed + '%</span>' +
        '<span style="color:var(--text-tri)">→</span>' +
        '<span style="color:var(--cyan);font-weight:700">' + dLoc + '%</span>' +
        '<span style="color:' + gapColor + ';font-weight:800;font-size:10px">' + gapSign + dGap.toFixed(1) + 'pp</span>' +
        '</div>' +
        '</div>';
    });
    $('compare-grid').innerHTML = grid;
    
    document.querySelectorAll('.compare-row-id').forEach(function(el){
      el.addEventListener('click', function(){ enterDistrito(parseInt(el.dataset.df)); });
    });
    
    // Narrativa
    const fedMejor = fedWinsB1 - locWinsB1;
    const oportunidad = 12 - locWinsB1;
    let narr = '<b>📊 Lectura estratégica:</b><br>';
    narr += 'En la <b>boleta federal (DipF 2024)</b>, el <b>' + blockNames[1] + '</b> alcanza <span class="num">' + fedAvg.toFixed(1) + '%</span> promedio y gana en <span class="num">' + fedWinsB1 + ' de 12</span> distritos objetivo. ';
    narr += 'En cambio, en la <b>boleta local (DipL 2024)</b>, el mismo bloque solo logra <span class="num">' + locAvg.toFixed(1) + '%</span> y gana <span class="num">' + locWinsB1 + ' de 12</span>. ';
    if (brecha > 5) {
      narr += '<br><br>🎯 <b>Brecha de arrastre detectada:</b> hay <span class="num">' + brecha.toFixed(1) + ' puntos porcentuales</span> de diferencia. ';
      narr += 'Significa que <b>cada elección hay miles de votos federales que no se traducen en voto local</b>. ';
      narr += 'Mi candidatura busca <b>cerrar esa brecha</b>: hacer que la fuerza federal de MORENA convertirla en escaños locales en estos ' + oportunidad + ' distritos pendientes.';
    } else if (brecha > 0) {
      narr += '<br><br>✅ <b>Brecha controlable:</b> solo ' + brecha.toFixed(1) + 'pp de diferencia entre federal y local. ';
      narr += 'La estructura electoral está alineada — falta consolidar los ' + oportunidad + ' distritos donde aún no ganamos lo local.';
    } else {
      narr += '<br><br>🚀 <b>Local supera al federal:</b> el voto duro de Jalisco para MORENA es más fuerte en la boleta local. ';
      narr += 'Excelente base para crecer.';
    }
    $('compare-narrative').innerHTML = narr;
  }
  
  // === ANÁLISIS DEL CANDIDATO: ESCENARIOS DE COALICIÓN ===
  // Replica el análisis manuscrito del candidato:
  // - Por distrito: voto Morena solo, MC, Megaalianza (SHHJ ampliada), MC+PAN
  // - Conclusiones: en qué distritos pierde Morena ante alianza opositora
  function renderCandidatoAnalisis() {
    const DF_OBJ = [3,4,6,7,9,10,11,12,13,14,16,20];
    const elecKey = 'd24';  // Diputado Local 2024 (la boleta del escaño objetivo)
    
    // Para cada distrito calcular votos en 5 escenarios reales
    const data = DF_OBJ.map(function(df){
      const pool = DATA.filter(function(d){return d[2] === df;});
      let totalVV = 0;
      let votosMorenaSolo = 0, votosMC = 0, votosMegaalianza = 0, votosMCPAN = 0;
      let votosMorenaPT = 0;  // NUEVO: alianza MORENA+PT (sin PVEM, etc.)
      
      let votosPAN = 0, votosMCPANPVEM = 0;
      pool.forEach(function(d){
        const e = getElec(d, elecKey); if (!e) return;
        totalVV += e.vv;
        // Morena solo (sin combos)
        votosMorenaSolo += e.partidos[PARTIES.indexOf('MORENA')].solo;
        // MC solo
        votosMC += e.partidos[PARTIES.indexOf('MC')].solo;
        // PAN solo
        votosPAN += e.partidos[PARTIES.indexOf('PAN')].solo;
        // Megaalianza = SHHJ ampliada con TODOS los combos
        votosMegaalianza += blockTotal(d, elecKey, ['MORENA','PT','PVEM','HAGAMOS','FUTURO']);
        // Morena + PT (con combos)
        votosMorenaPT += blockTotal(d, elecKey, ['MORENA','PT']);
        // MC + PAN hipotético
        votosMCPAN += e.partidos[PARTIES.indexOf('MC')].solo + e.partidos[PARTIES.indexOf('PAN')].solo;
        // MC + PAN + PVEM hipotético (oposición unida)
        votosMCPANPVEM += e.partidos[PARTIES.indexOf('MC')].solo + e.partidos[PARTIES.indexOf('PAN')].solo + e.partidos[PARTIES.indexOf('PVEM')].solo;
      });
      
      return {
        df: df,
        totalVV: totalVV,
        morenaSolo: votosMorenaSolo,
        morenaPT: votosMorenaPT,
        mc: votosMC,
        pan: votosPAN,
        megaalianza: votosMegaalianza,
        mcpan: votosMCPAN,
        mcpanpvem: votosMCPANPVEM,
        margenMorenaVsMC: votosMorenaSolo - votosMC,
        margenMorenaPTvsMCPANPVEM: votosMorenaPT - votosMCPANPVEM,
        diffMegaVsMCPAN: votosMegaalianza - votosMCPAN,
        diffMegaVsMCPANPVEM: votosMegaalianza - votosMCPANPVEM
      };
    });
    
    // CONCLUSIONES AUTOMÁTICAS estilo manuscrito del candidato (TODOS los 12)
    const conclusionsEl = $('cand-conclusions');
    if (conclusionsEl) {
      let html = '';
      // Resumen alarmante arriba
      let perdMPT = 0, perdMega = 0, ganMPTvsMCPANPVEM = 0;
      data.forEach(function(d){
        if (d.morenaPT < d.mc) perdMPT++;
        if (d.megaalianza < d.mcpanpvem) perdMega++;
        if (d.morenaPT > d.mcpanpvem) ganMPTvsMCPANPVEM++;
      });
      html += '<div style="background:rgba(0,240,255,0.08);border-left:4px solid var(--cyan);padding:12px 16px;border-radius:0 8px 8px 0;margin-bottom:14px;font-size:12px">';
      html += '<b style="color:var(--cyan)">📊 Resumen estratégico (DipL 2024):</b><br>';
      html += '• <b>MORENA+PT solo</b> vs MC solo: <span class="num">' + (12-perdMPT) + '/12</span> distritos ganaríamos · <span class="danger">' + perdMPT + '/12</span> perderíamos<br>';
      html += '• <b>MORENA+PT</b> vs <b>MC+PAN+PVEM</b>: <span class="num">' + ganMPTvsMCPANPVEM + '/12</span> distritos ganaríamos · <span class="danger">' + (12-ganMPTvsMCPANPVEM) + '/12</span> perderíamos<br>';
      html += '• <b>Megaalianza SHHJ</b> vs <b>MC+PAN+PVEM</b>: <span class="num">' + (12-perdMega) + '/12</span> distritos ganaríamos · <span class="danger">' + perdMega + '/12</span> perderíamos';
      html += '</div>';
      
      // Por distrito
      data.forEach(function(d){
        const mptGana = d.morenaPT > d.mc;
        const mptVsCoalOp = d.morenaPT > d.mcpanpvem;
        const megaVsCoalOp = d.megaalianza > d.mcpanpvem;
        
        let html_dist = '<div class="cand-conclusion">';
        html_dist += '<b>Distrito ' + d.df + ':</b> ';
        
        if (mptGana) {
          html_dist += '✅ MORENA+PT ganó por <span class="num">' + Math.abs(d.morenaPT - d.mc).toLocaleString('es-MX') + '</span> votos sobre MC solo. ';
        } else {
          html_dist += '❌ <span class="danger">MORENA+PT perdió</span> por <span class="danger">' + Math.abs(d.mc - d.morenaPT).toLocaleString('es-MX') + '</span> votos contra MC solo. ';
        }
        
        if (mptVsCoalOp) {
          html_dist += 'Frente a <b>MC+PAN+PVEM</b> aliados: <b>MORENA+PT vence</b> por <span class="num">' + Math.abs(d.morenaPT - d.mcpanpvem).toLocaleString('es-MX') + '</span> votos. ';
        } else if (megaVsCoalOp) {
          html_dist += 'Frente a MC+PAN+PVEM aliados, <span class="danger">MORENA+PT pierde</span> por <span class="danger">' + Math.abs(d.mcpanpvem - d.morenaPT).toLocaleString('es-MX') + '</span>, pero la <b>Megaalianza SHHJ vence</b> por <span class="num">' + Math.abs(d.diffMegaVsMCPANPVEM).toLocaleString('es-MX') + '</span>.';
        } else {
          html_dist += '<span class="danger">Ni la Megaalianza vence</span> a MC+PAN+PVEM — perdería por <span class="danger">' + Math.abs(d.diffMegaVsMCPANPVEM).toLocaleString('es-MX') + '</span> votos.';
        }
        
        html_dist += '</div>';
        html += html_dist;
      });
      
      conclusionsEl.innerHTML = html;
    }
    
    // TABLA replicando estructura del candidato
    const tableEl = $('cand-table');
    if (tableEl) {
      let html = '<thead><tr>' +
        '<th style="text-align:left">Zona</th>' +
        '<th style="text-align:left">Distrito · Candidato</th>' +
        '<th>MORENA+PT</th>' +
        '<th>MC solo</th>' +
        '<th>PAN solo</th>' +
        '<th>MC+PAN+PVEM</th>' +
        '<th>Megaalianza SHHJ</th>' +
        '<th>Diferencia</th>' +
        '<th>Veredicto</th>' +
        '</tr></thead><tbody>';
      
      // Agrupación por zona
      const ZONAS = {
        'Guadalajara': [9, 11, 13],
        'Zapopan': [4, 6, 10, 12],
        'Tonalá': [7, 16, 20],
        'Tlajomulco': [14],
        'Tepatitlán': [3]
      };
      
      Object.keys(ZONAS).forEach(function(zona){
        ZONAS[zona].forEach(function(df, i){
          const d = data.find(function(dd){return dd.df === df;});
          if (!d) return;
          const cand = (DL_WIN[df] || DL_WIN[String(df)]);
          const candName = cand ? (cand.nombre.split(' ')[0] + ' (' + cand.partido + ')') : '—';
          
          // Diferencia ganador = max(propuesta nuestra) - max(propuesta oposición)
          const nuestroMax = Math.max(d.morenaPT, d.megaalianza);
          const opMax = Math.max(d.mcpanpvem, d.mc, d.pan);
          const diff = nuestroMax - opMax;
          
          const winnerCol = Math.max(d.morenaPT, d.mc, d.pan, d.mcpanpvem, d.megaalianza);
          const morenaWins = (d.morenaPT === winnerCol || d.megaalianza === winnerCol);
          
          html += '<tr' + (morenaWins ? ' class="winner-row"' : '') + '>';
          html += '<td>' + (i === 0 ? '<b>' + zona + '</b>' : '') + '</td>';
          html += '<td>D' + df + ' · ' + candName + '</td>';
          html += '<td' + (d.morenaPT === winnerCol ? ' class="win"' : '') + '>' + d.morenaPT.toLocaleString('es-MX') + '</td>';
          html += '<td' + (d.mc === winnerCol ? ' class="danger"' : '') + '>' + d.mc.toLocaleString('es-MX') + '</td>';
          html += '<td>' + d.pan.toLocaleString('es-MX') + '</td>';
          html += '<td' + (d.mcpanpvem === winnerCol ? ' class="danger"' : '') + '>' + d.mcpanpvem.toLocaleString('es-MX') + '</td>';
          html += '<td' + (d.megaalianza === winnerCol ? ' class="win"' : '') + '>' + d.megaalianza.toLocaleString('es-MX') + '</td>';
          const diffSign = diff >= 0 ? '+' : '';
          html += '<td style="text-align:center;font-weight:800;color:' + (diff >= 0 ? 'var(--green)' : 'var(--red)') + '">' + diffSign + diff.toLocaleString('es-MX') + '</td>';
          html += '<td style="text-align:center">' + (d.megaalianza > d.mcpanpvem ? '✅ Mega gana' : (d.morenaPT > d.mcpanpvem ? '✅ MorPT gana' : '❌ Mega pierde')) + '</td>';
          html += '</tr>';
        });
      });
      html += '</tbody>';
      tableEl.innerHTML = html;
    }
    
    // GRÁFICA: replica la del candidato (barras horizontales por distrito x escenario)
    // EXTENDIDO A LOS 12 DISTRITOS · ORDENADO por escenario MÁS GRANDE
    const chartEl = $('cand-chart');
    if (chartEl) {
      const W = chartEl.clientWidth || 700;
      // Pre-calcular MPTV (Morena+PT+PVEM) para cada distrito
      const dataAll = data.map(function(d){
        // Para ordenar: tomar el total de votos válidos del distrito
        const sortVal = d.totalVV;
        return Object.assign({}, d, { sortVal: sortVal });
      });
      
      // ORDENAR de mayor a menor por votos totales del distrito
      dataAll.sort(function(a, b){ return b.sortVal - a.sortVal; });
      
      const rowH = 130;  // más alto: ahora son 6 barras por distrito
      const PAD_L = 80, PAD_R = 90, PAD_T = 30, PAD_B = 30;
      const H = PAD_T + PAD_B + dataAll.length * rowH;
      const innerW = W - PAD_L - PAD_R;
      
      let maxV = 0;
      dataAll.forEach(function(d){
        maxV = Math.max(maxV, d.morenaPT, d.mc, d.pan, d.mcpanpvem, d.megaalianza);
      });
      maxV = Math.ceil(maxV / 20000) * 20000;
      
      const xAt = function(v){ return PAD_L + (v / maxV) * innerW; };
      
      const ESCENARIOS = [
        { key: 'morenaPT', label: 'MORENA + PT', color: '#a01818' },
        { key: 'mc', label: 'MC solo', color: '#ff8c00' },
        { key: 'pan', label: 'PAN solo', color: '#1a5fb4' },
        { key: 'mcpanpvem', label: 'MC + PAN + PVEM', color: '#0d3b66' },
        { key: 'megaalianza', label: 'Megaalianza SHHJ', color: '#7b1fa2' },
      ];
      const barH = 13;
      const barGap = 2;
      
      let svg = '<svg viewBox="0 0 ' + W + ' ' + H + '" preserveAspectRatio="xMidYMid meet" style="width:100%;display:block">';
      
      // Grid
      for (let i = 0; i <= 5; i++) {
        const v = (maxV / 5) * i;
        const x = xAt(v);
        svg += '<line x1="' + x + '" y1="' + PAD_T + '" x2="' + x + '" y2="' + (H-PAD_B) + '" stroke="rgba(140,180,240,0.15)" stroke-width="1"/>';
        svg += '<text x="' + x + '" y="' + (PAD_T-8) + '" text-anchor="middle" style="font-size:9px;fill:var(--text-tri)">' + (v/1000).toFixed(0) + 'K</text>';
      }
      
      dataAll.forEach(function(d, di){
        const yTop = PAD_T + di * rowH + 4;
        // Etiqueta distrito + ranking de orden
        svg += '<text x="' + (PAD_L-12) + '" y="' + (yTop + 38) + '" text-anchor="end" style="font-size:14px;font-weight:800;fill:var(--gold);font-family:inherit">D' + d.df + '</text>';
        svg += '<text x="' + (PAD_L-12) + '" y="' + (yTop + 52) + '" text-anchor="end" style="font-size:9px;font-weight:600;fill:var(--text-tri);font-family:inherit">#' + (di+1) + '</text>';
        // Línea separadora
        if (di > 0) {
          svg += '<line x1="' + PAD_L + '" y1="' + (yTop - 4) + '" x2="' + (W-PAD_R) + '" y2="' + (yTop - 4) + '" stroke="rgba(140,180,240,0.1)"/>';
        }
        ESCENARIOS.forEach(function(esc, ei){
          const v = d[esc.key];
          const w = (v / maxV) * innerW;
          const y = yTop + ei * (barH + barGap);
          // Resaltar la barra del escenario MÁXIMO
          const isMax = v === d.maxScenario;
          const op = isMax ? 1.0 : 0.75;
          svg += '<rect x="' + PAD_L + '" y="' + y + '" width="' + Math.max(2, w) + '" height="' + barH + '" fill="' + esc.color + '" opacity="' + op + '"' + (isMax ? ' stroke="#fff" stroke-width="1.5"' : '') + '><title>' + esc.label + ': ' + v.toLocaleString('es-MX') + '</title></rect>';
          // Etiqueta del nombre antes de la barra
          svg += '<text x="' + (PAD_L - 4) + '" y="' + (y + 10) + '" text-anchor="end" style="font-size:9px;font-weight:' + (isMax?'800':'700') + ';fill:' + esc.color + '">' + esc.label + '</text>';
          // Valor al final
          svg += '<text x="' + (PAD_L + w + 6) + '" y="' + (y + 10) + '" style="font-size:10px;font-weight:' + (isMax?'800':'700') + ';fill:' + esc.color + '">' + v.toLocaleString('es-MX') + (isMax?' ★':'') + '</text>';
        });
      });
      
      svg += '</svg>';
      chartEl.innerHTML = svg;
    }
  }

  // === MAPA DE CALOR DE DISTRITOS ===
  function renderHeatmap(elecKey) {
    const DF_OBJ = [3,4,6,7,9,10,11,12,13,14,16,20];
    const distritos = DF_OBJ.map(function(df){
      const rows = DATA.filter(function(d){return d[2] === df;});
      let totalVV = 0, b1V = 0;
      rows.forEach(function(d){
        const e = getElec(d, elecKey); if (!e) return;
        totalVV += e.vv;
        b1V += blockTotal(d, elecKey, blocks[1]);
      });
      return {
        df: df,
        secciones: rows.length,
        b1pct: totalVV>0 ? b1V/totalVV*100 : 0,
        winner: getWinner(df)
      };
    });
    const maxPct = Math.max.apply(null, distritos.map(function(d){return d.b1pct;}));
    const minPct = Math.min.apply(null, distritos.map(function(d){return d.b1pct;}));
    
    // Ordenar por b1pct descendente para asignar rank
    const sorted = distritos.slice().sort(function(a,b){return b.b1pct - a.b1pct;});
    const rankMap = {};
    sorted.forEach(function(d, i){ rankMap[d.df] = i+1; });
    
    function heatColor(pct) {
      // Escala: amarillo → naranja → rojo según ratio
      const range = maxPct - minPct;
      const ratio = range > 0 ? (pct - minPct) / range : 0.5;
      // Color stops
      const stops = [
        [0.0, [255, 245, 157]],   // #b4fab4 amarillo claro
        [0.25, [255, 179, 0]],     // #fff582 amarillo intenso
        [0.5, [245, 124, 0]],      // #ffa532 naranja
        [0.75, [216, 67, 21]],     // #dc321e rojo-naranja
        [1.0, [183, 28, 28]],      // #78141e rojo
      ];
      let c1 = stops[0], c2 = stops[stops.length-1];
      for (let i=0; i<stops.length-1; i++) {
        if (ratio >= stops[i][0] && ratio <= stops[i+1][0]) {
          c1 = stops[i]; c2 = stops[i+1]; break;
        }
      }
      const localR = (ratio - c1[0]) / (c2[0] - c1[0]);
      const r = Math.round(c1[1][0] + (c2[1][0] - c1[1][0]) * localR);
      const g = Math.round(c1[1][1] + (c2[1][1] - c1[1][1]) * localR);
      const b = Math.round(c1[1][2] + (c2[1][2] - c1[1][2]) * localR);
      return 'rgb(' + r + ',' + g + ',' + b + ')';
    }
    
    // Render en orden por DF (no por rank) para que sea predecible
    distritos.sort(function(a,b){return a.df - b.df;});
    
    let html = '';
    distritos.forEach(function(d){
      const color = heatColor(d.b1pct);
      const rank = rankMap[d.df];
      const winnerInfo = d.winner ? d.winner.partido : '?';
      html += '<div class="heat-cell" style="background:' + color + '" data-df="' + d.df + '">' +
        '<div class="heat-cell-rank">#' + rank + '</div>' +
        '<div class="heat-cell-df">' + (modoNivel==="federal"?"DF ":"DL ") + d.df + '</div>' +
        '<div class="heat-cell-pct">' + d.b1pct.toFixed(1) + '%</div>' +
        '<div class="heat-cell-info">' + d.secciones + ' sec · ' + winnerInfo + '</div>' +
        '</div>';
    });
    $('heatmap-grid').innerHTML = html;
    
    document.querySelectorAll('.heat-cell').forEach(function(c){
      c.addEventListener('click', function(){ enterDistrito(parseInt(c.dataset.df)); });
    });
  }

