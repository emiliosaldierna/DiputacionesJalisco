  function renderDiscurso() {
    const pool = getDLFilter();
    const elecKey = getCurrentElecKey();
    const gKey = ELEC_YEARS.g[0].key;  // gob más reciente como referencia
    
    let g_b1 = 0, g_VV = 0, d_b1 = 0, d_VV = 0;
    pool.forEach(function(d){
      const eg = getElec(d, gKey); if (eg) { g_VV += eg.vv; g_b1 += blockTotal(d, gKey, blocks[1]); }
      const ed = getElec(d, elecKey); if (ed) { d_VV += ed.vv; d_b1 += blockTotal(d, elecKey, blocks[1]); }
    });
    const gPct = g_VV>0 ? g_b1/g_VV*100 : 0;
    const dPct = d_VV>0 ? d_b1/d_VV*100 : 0;
    const brecha = gPct - dPct;
    const techo = g_b1 - d_b1;
    
    let bastiones = 0, arrastre = 0, estr = 0;
    pool.forEach(function(d){
      const ed = getElec(d, elecKey); if (!ed) return;
      const dB1 = blockTotal(d, elecKey, blocks[1]);
      const dB2 = blockTotal(d, elecKey, blocks[2]);
      const dB3 = blockTotal(d, elecKey, blocks[3]);
      const dMax = Math.max(dB1, dB2, dB3);
      const dMaxIdx = dMax === dB1 ? 1 : (dMax === dB2 ? 2 : 3);
      const sortedD = [dB1, dB2, dB3].sort(function(a,b){return b-a;});
      const dMargenPct = ed.vv>0 ? (sortedD[0] - sortedD[1])/ed.vv*100 : 0;
      if (dMaxIdx === 1 && dMargenPct > 15) bastiones++;
      const eg = getElec(d, gKey); if (!eg) return;
      const gB1 = blockTotal(d, gKey, blocks[1]);
      const gB2 = blockTotal(d, gKey, blocks[2]);
      const gB3 = blockTotal(d, gKey, blocks[3]);
      const gMax = Math.max(gB1, gB2, gB3);
      const gMaxIdx = gMax === gB1 ? 1 : (gMax === gB2 ? 2 : 3);
      if (gMaxIdx === 1 && dMaxIdx !== 1 && eg.vv > 0 && ed.vv > 0) arrastre++;
      if (dMargenPct > 0 && dMargenPct < 5 && ed.vv > 0) estr++;
    });
    
    const DF_OBJ = [3,4,6,7,9,10,11,12,13,14,16,20];
    const ranks = DF_OBJ.map(function(df){
      const rs = DATA.filter(function(d){return d[2] === df;});
