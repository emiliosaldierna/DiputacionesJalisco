    const pool = getDLFilter();
    const elecKey = getCurrentElecKey();  // sincronizado con filtro principal
    
    // ============ MODO POR DISTRITO ============
    if (currentMapView === 'distrito') {
      // Calcular ganador del distrito
      let b1Total = 0, b2Total = 0, b3Total = 0;
      pool.forEach(function(d){
        b1Total += blockTotal(d, elecKey, blocks[1]);
        b2Total += blockTotal(d, elecKey, blocks[2]);
        b3Total += blockTotal(d, elecKey, blocks[3]);
      });
      const totals = [b1Total, b2Total, b3Total];
      const winnerIdx = totals.indexOf(Math.max.apply(null, totals));
      let fillColor = BLOCK_COLORS[winnerIdx];
      let opacity = 0.78;
      // En modo Por Partidos individuales, usar el partido ganador del distrito
      if (currentMapFilter === 'PARTY:MODE') {
        let partyTotals = {};
        PARTIES.forEach(function(p){ partyTotals[p] = 0; });
        pool.forEach(function(d){
          const e = getElec(d, elecKey); if (!e) return;
          PARTIES.forEach(function(p, idx){
            partyTotals[p] += e.partidos[idx].solo;
          });
        });
        let maxV = 0, winP = null;
        PARTIES.forEach(function(p){ if (partyTotals[p] > maxV) { maxV = partyTotals[p]; winP = p; } });
        if (winP) fillColor = PARTY_COLORS[winP] || '#5a6b8a';
      }
      const totalVV = b1Total + b2Total + b3Total;
      const elecLabel = (TIPO_LABELS[currentTipo] || '').toUpperCase() + ' ' + currentAnio;
      const pop = '<div style="font-family:sans-serif;font-size:12px;min-width:220px;color:#000;font-weight:700">' +
        '<div style="font-weight:800;color:#a01818;font-size:14px">' + (modoNivel==="federal"?"Distrito Federal ":"Distrito Local ") + currentDF + '</div>' +
        '<div style="color:#000">' + pool.length + ' secciones</div>' +
        '<hr style="border:none;border-top:1px solid #ccc;margin:6px 0">' +
        '<div style="font-size:10px;color:#000;font-weight:600">' + elecLabel + '</div>' +
        '<div style="margin-top:6px"><b style="color:#000">' + blockNames[1] + ':</b> ' + fmt(b1Total) + ' (' + (totalVV>0?(b1Total/totalVV*100).toFixed(1):'0') + '%)</div>' +
        '<div><b style="color:#000">' + blockNames[2] + ':</b> ' + fmt(b2Total) + ' (' + (totalVV>0?(b2Total/totalVV*100).toFixed(1):'0') + '%)</div>' +
        '<div><b style="color:#000">' + blockNames[3] + ':</b> ' + fmt(b3Total) + ' (' + (totalVV>0?(b3Total/totalVV*100).toFixed(1):'0') + '%)</div>' +
        '</div>';
      
      // Pintar TODAS las secciones del distrito con el color del distrito (sin bordes internos)
      pool.forEach(function(d){
        const sec = d[0];
        const polyCoords = SECTION_POLYS[sec] || SECTION_POLYS[String(sec)];
        if (polyCoords && polyCoords.length >= 3) {
          const shape = L.polygon(polyCoords, {
            color: fillColor, weight: 0, opacity: 0,
            fillColor: fillColor, fillOpacity: Math.max(opacity, 0.85)
          });
          shape.bindPopup(pop);
          polyLayer.addLayer(shape);
        }
      });
      
      // (Borde dorado eliminado - estaba mal, era convex hull)
    } else {
      // ============ MODO POR SECCIÓN (default) ============
      // Render de TODAS las secciones de Jalisco (contexto)
      // Las del distrito actual van con color de bloque ganador
      // Las demás van en gris muy tenue para mostrar el contexto del estado
      const currentDFNum = currentDF;
      const currentSecs = {};
      pool.forEach(function(d){ currentSecs[d[0]] = d; });
      
      // Secciones de los 12 distritos objetivo (que NO son el actual)
      const DF_OBJ_SET = {3:1,4:1,6:1,7:1,9:1,10:1,11:1,12:1,13:1,14:1,16:1,20:1};
      
      Object.keys(SECTION_POLYS).forEach(function(secId){
        const coords = SECTION_POLYS[secId];
        if (!coords || coords.length < 3) return;
        const meta = SECTION_META[secId] || {};
        const secNum = parseInt(secId);
        const inCurrent = currentSecs[secNum] !== undefined;
        if (inCurrent) return;  // las renderizamos después en color completo
        
        const isObjDist = DF_OBJ_SET[meta.df];
        // Estilo según si es distrito objetivo o no
        let style;
        if (isObjDist) {
          // Distrito objetivo pero no el actual: gris medio
          style = {
            color: '#3a4558', weight: 0.3, opacity: 0.5,
            fillColor: '#1f2838', fillOpacity: 0.5
          };
        } else {
          // Resto de Jalisco: gris muy tenue (contexto)
          style = {
            color: '#2a3142', weight: 0.2, opacity: 0.4,
            fillColor: '#10141d', fillOpacity: 0.45
          };
        }
        const shape = L.polygon(coords, style);
        polyLayer.addLayer(shape);
      });
      
      // (Polígono guía del distrito eliminado - convex hull no representa bien la forma)
      
      // Por cada sección: polígono real (si existe) o circleMarker como fallback
      pool.forEach(function(d){
        if (!d[4] || !d[5]) return;
        const color = getColor(d);
        const e = getElec(d, elecKey);
        if (!e) return;
        
        const sec = d[0];
        const polyCoords = SECTION_POLYS[sec] || SECTION_POLYS[String(sec)];
        
        const elecLabel = (TIPO_LABELS[currentTipo] || '').toUpperCase() + ' ' + currentAnio;
        const b1V = blockTotal(d, elecKey, blocks[1]);
        const b2V = blockTotal(d, elecKey, blocks[2]);
        const b3V = blockTotal(d, elecKey, blocks[3]);
        const winnerB = b1V >= b2V && b1V >= b3V ? blockNames[1] : (b2V >= b3V ? blockNames[2] : blockNames[3]);
        const winnerPct = e.vv > 0 ? Math.max(b1V,b2V,b3V)/e.vv*100 : 0;
        
        const pop = '<div style="font-family:sans-serif;font-size:12px;min-width:220px;color:#000;font-weight:700">' +
          '<div style="font-weight:800;color:#a01818;font-size:14px">Sección ' + String(d[0]).padStart(4,'0') + '</div>' +
          '<div style="color:#000;font-weight:700">' + MUNIS[d[1]] + ' · ' + (modoNivel==="federal"?"DF ":"DL ") + d[2] + '</div>' +
          '<hr style="border:none;border-top:1px solid #ccc;margin:6px 0">' +
          '<div style="font-size:10px;color:#000;font-weight:600">' + elecLabel + '</div>' +
          '<div style="color:#000;font-weight:700">Lista nominal: <span style="color:#000;font-weight:700">' + fmt(e.ln) + '</span></div>' +
          '<div style="color:#000;font-weight:700">Votos válidos: <span style="color:#000;font-weight:700">' + fmt(e.vv) + '</span></div>' +
          '<div style="color:#000;font-weight:700">Participación: <span style="color:#000;font-weight:700">' + (e.ln>0?(e.vv/e.ln*100).toFixed(1):'0') + '%</span></div>' +
          '<hr style="border:none;border-top:1px solid #ccc;margin:6px 0">' +
          '<div style="margin-top:4px;color:#000;font-weight:700"><b style="color:#000">' + blockNames[1] + ':</b> ' + fmt(b1V) + ' (' + (e.vv>0?(b1V/e.vv*100).toFixed(1):'0') + '%)</div>' +
          '<div style="color:#000;font-weight:700"><b style="color:#000">' + blockNames[2] + ':</b> ' + fmt(b2V) + ' (' + (e.vv>0?(b2V/e.vv*100).toFixed(1):'0') + '%)</div>' +
          '<div style="color:#000;font-weight:700"><b style="color:#000">' + blockNames[3] + ':</b> ' + fmt(b3V) + ' (' + (e.vv>0?(b3V/e.vv*100).toFixed(1):'0') + '%)</div>' +
          '<div style="margin-top:6px;padding:4px 6px;background:rgba(160,24,24,0.08);border-radius:4px;color:#000;font-weight:800">Ganador: ' + winnerB + ' (' + winnerPct.toFixed(1) + '%)</div>' +
          '</div>';
        
        if (polyCoords && polyCoords.length >= 3) {
          // Polígono real de sección
          const shape = L.polygon(polyCoords, {
            color: '#0a0e1a', weight: 0.7, opacity: 0.9,
            fillColor: color, fillOpacity: 0.78
          });
          shape.bindPopup(pop);
          polyLayer.addLayer(shape);
        }
        // (circleMarker fallback eliminado en mapa micro)
      });
    }
    
    polyLayer.addTo(map);
    
    // Ajustar zoom: si modo distrito o sección, centrar en el distrito actual
    // (no incluir las secciones de contexto en el cálculo)
    const valid = pool.filter(function(d){return d[4] && d[5];});
    if (valid.length > 0) {
      const bounds = L.latLngBounds(valid.map(function(d){return [d[4], d[5]];}));
      if (bounds.isValid()) map.fitBounds(bounds, { padding: [40,40], maxZoom: 13 });
    }
    
    const viewSuffix = currentMapView === 'distrito' ? ' · Vista: distrito completo' : ' · Vista: por sección electoral';
    $('map-title').textContent = '🗺️ ' + (TIPO_LABELS[currentTipo] || '') + ' ' + currentAnio + ' · Color = bloque ganador' + viewSuffix;
  }
  
  function setMacroView(macro, v) {
    if (macro === '1') {
      currentMacroView1 = v;
    } else {
      currentMacroView2 = v;
    }
    document.querySelectorAll('.mapview-btn[data-macro="' + macro + '"]').forEach(function(b){
      b.classList.toggle('active', b.dataset.view === v);
    });
    const ek = getCurrentElecKey();
    if (ek) {
      if (macro === '1') renderMacroMapWinner(ek);
      else renderMacroMapHeat(ek);
    }
  }
  
  function setMapView(v) {
    currentMapView = v;
    document.querySelectorAll('.mapview-btn').forEach(function(b){
      b.classList.toggle('active', b.dataset.view === v);
    });
    renderMap();
  }

  function renderLegend() {
    if (currentMapFilter === 'auto') {
      $('legend').innerHTML =
        '<div class="legend-item"><span class="legend-dot" style="background:' + BLOCK_COLORS[0] + '"></span><b>' + blockNames[1] + '</b></div>' +
        '<div class="legend-item"><span class="legend-dot" style="background:' + BLOCK_COLORS[1] + '"></span><b>' + blockNames[2] + '</b></div>' +
        '<div class="legend-item"><span class="legend-dot" style="background:' + BLOCK_COLORS[2] + '"></span><b>' + blockNames[3] + '</b></div>';
    } else {
      // Filtro específico: mostrar escala de intensidad
      let label = '', color = '';
      if (currentMapFilter === 'B1') { label = blockNames[1]; color = BLOCK_COLORS[0]; }
      else if (currentMapFilter === 'B2') { label = blockNames[2]; color = BLOCK_COLORS[1]; }
      else if (currentMapFilter === 'B3') { label = blockNames[3]; color = BLOCK_COLORS[2]; }
      else if (currentMapFilter.indexOf('PARTY:') === 0) {
        const p = currentMapFilter.split(':')[1];
        label = p; color = PARTY_COLORS[p] || '#5a6b8a';
      }
      $('legend').innerHTML =
        '<div class="legend-item"><span style="font-weight:700;color:' + color + '">' + label + '</span> · <span style="color:var(--text-tri)">Intensidad de color = % de voto en cada sección</span></div>' +
        '<div class="legend-item" style="margin-left:8px"><span class="legend-dot" style="background:#2a3548"></span>0%</div>' +
        '<div class="legend-item"><span class="legend-dot" style="background:' + color + '"></span>60%+</div>';
    }
  }


  function renderSeccionList(elecKey) {
    const pool = getDLFilter();
    const secs = pool.slice().sort(function(a,b){
      const ea = getElec(a, elecKey), eb = getElec(b, elecKey);
      const ap = ea && ea.vv>0 ? blockTotal(a, elecKey, blocks[1])/ea.vv*100 : 0;
      const bp = eb && eb.vv>0 ? blockTotal(b, elecKey, blocks[1])/eb.vv*100 : 0;
      return bp - ap;
    }).slice(0, 10);
    let html = '';
    secs.forEach(function(d, i){
      const e = getElec(d, elecKey); if (!e) return;
      const b1 = blockTotal(d, elecKey, blocks[1]);
      const pct = e.vv>0 ? b1/e.vv*100 : 0;
      html += '<div style="display:grid;grid-template-columns:30px 60px 1fr 60px;gap:8px;padding:8px 10px;background:rgba(5,8,16,0.5);border-left:3px solid var(--b1);border-radius:4px;margin-bottom:4px;font-size:11px;align-items:center">' +
        '<span style="font-weight:800;color:var(--gold);font-size:14px;text-align:center">' + (i+1) + '</span>' +
        '<span style="font-family:monospace;color:var(--cyan);font-weight:700">' + String(d[0]).padStart(4,'0') + '</span>' +
        '<span style="color:var(--text-pri);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + MUNIS[d[1]] + '<br><span style="color:var(--text-tri);font-size:9px">DL' + d[3] + ' · LN ' + fmt(e.ln) + '</span></span>' +
        '<span style="text-align:right;font-weight:700;color:var(--b1)">' + pct.toFixed(1) + '%</span>' +
        '</div>';
    });
    if (secs.length === 0) html = '<div style="text-align:center;padding:20px;color:var(--text-tri)">Sin datos</div>';
    $('seccion-list').innerHTML = html;
  }

  function copyDiscurso() {
    const text = $('discurso-content').innerText;
    if (navigator.clipboard) {
      navigator.clipboard.writeText(text).then(function(){ alert('✓ Copiado'); }).catch(function(){ alert('Error'); });
    }
  }

  function init() {
    // Exponer enterDistrito a window para uso desde popups HTML
    if (typeof window !== 'undefined') window._enterDist = enterDistrito;
    try {
      loadData();
      
      // Filtro principal
      $('gf-tipo').addEventListener('change', function(){
        currentTipo = this.value;
        // Sincronizar layer del mapa micro con tipo seleccionado
        // currentTipo es 'g'/'a'/'d'/'f', currentLayer usa los mismos códigos (excepto 'f' que mapeamos a 'd' por compatibilidad)
        currentLayer = (currentTipo === 'f') ? 'd' : currentTipo;
        modoNivel = (currentTipo === 'f') ? 'federal' : 'local';
        currentHistTipo = currentTipo;       // sincroniza con histórica macro
        currentHistMicroTipo = currentTipo;  // sincroniza con histórica micro
        updateAnioOptions();
        // Actualizar textos dinámicos visibles
        const thDist = document.getElementById('th-distrito');
        const thDip = document.getElementById('th-dip');
        if (thDist) thDist.textContent = (modoNivel==='federal'?'Distrito Federal':'Distrito Local');
        if (thDip) thDip.textContent = 'Diputado(a) ' + (modoNivel==='federal'?'Federal':'Local') + ' electo(a) 2024';
        const rkLabel = document.getElementById('rk-niv-label');
        if (rkLabel) rkLabel.textContent = (modoNivel==='federal'?'federal':'local');
        renderAll();
      });
      // Wire-up de filtros globales: distrito y sección
      const gfDist = document.getElementById('gf-distrito');
      const gfSec = document.getElementById('gf-seccion');
      if (gfDist) {
        gfDist.addEventListener('change', function(){
          currentDFFilter = this.value;
          populateSeccionOptions();
          if (currentDFFilter) {
            currentDF = parseInt(currentDFFilter);
            // entra a vista detalle del distrito
            populateMicroFilters();
            renderAll();
            setTimeout(function(){
              const c = document.getElementById('map');
              if (c && c.offsetWidth > 0) {
                if (!map && typeof L !== 'undefined') initMap();
                if (map) { map.invalidateSize(); renderMap(); }
              }
            }, 150);
          } else {
            currentDF = null;
            renderAll();
          }
        });
      }
      if (gfSec) {
        gfSec.addEventListener('change', function(){
          currentSeccionFilter = this.value;
          renderAll();
          // refrescar mapa si está visible
          setTimeout(function(){
            if (currentDF !== null && map) {
              map.invalidateSize();
              renderMap();
            }
          }, 100);
        });
      }
      
      $('gf-anio').addEventListener('change', function(){
        currentAnio = this.value;
        renderAll();
      });
      updateAnioOptions();
      
      // Histórico macro: el tipo lo hereda de currentTipo (el filtro principal)
      document.querySelectorAll('.hist-panel:first-of-type .hist-toggle-btn').forEach(function(b){
        b.addEventListener('click', function(){
          currentHistMode = this.dataset.mode;
          this.parentElement.querySelectorAll('.hist-toggle-btn').forEach(function(bb){bb.classList.remove('active');});
          this.classList.add('active');
          hiddenLines = new Set();
          currentHistTipo = currentTipo;  // sincroniza con principal
          renderHistChart('macro');
        });
      });
      
      // Histórico micro: igual, hereda de currentTipo
      document.querySelectorAll('#hist-micro-toggle .hist-toggle-btn').forEach(function(b){
        b.addEventListener('click', function(){
          currentHistMicroMode = this.dataset.mode;
          this.parentElement.querySelectorAll('.hist-toggle-btn').forEach(function(bb){bb.classList.remove('active');});
          this.classList.add('active');
          hiddenLinesMicro = new Set();
          currentHistMicroTipo = currentTipo;
          renderHistChart('micro');
        });
      });
      
      // Presets
      $('preset-shhj-mc-fre').addEventListener('click', function(){applyPreset('shhj-mc-fre');});
      $('preset-morena-alianza').addEventListener('click', function(){applyPreset('morena-alianza');});
      $('preset-tres-bloques').addEventListener('click', function(){applyPreset('tres-bloques');});
      $('reset-blocks').addEventListener('click', resetBlocks);
      
      document.querySelectorAll('.block-name').forEach(function(inp){
        inp.addEventListener('input', function(){
          blockNames[parseInt(inp.dataset.block)] = inp.value || ('Bloque ' + inp.dataset.block);
          renderAll();
        });
      });
      
      $('btn-back').addEventListener('click', exitToMacro);
      // Botón mini de regreso junto al toggle del mapa
      const btnBackMini = $('btn-back-mini');
      if (btnBackMini) btnBackMini.addEventListener('click', exitToMacro);
      // (Selectores f-dl y f-muni eliminados)
      const fDl = $('f-dl'); if (fDl) fDl.addEventListener('change', renderMicro);
      const fMuni = $('f-muni'); if (fMuni) fMuni.addEventListener('change', renderMicro);
      
      // Map style selectors (micro y macro)
      document.querySelectorAll('.mss-btn').forEach(function(b){
        b.addEventListener('click', function(){
          const target = b.dataset.target || 'micro';
          setMapStyle(b.dataset.style, target);
        });
      });
      
      // Compare chart controls
      ['cc-fed-key','cc-loc-key','cc-mode'].forEach(function(id){
        const el = $(id); if (el) el.addEventListener('change', renderCompareChart);
      });
      
      // (Layer-btn listeners eliminados - currentLayer se sincroniza con filtro principal)
      document.querySelectorAll('.mapview-btn').forEach(function(b){
        b.addEventListener('click', function(){
          if (this.dataset.macro) {
            setMacroView(this.dataset.macro, this.dataset.view);
          } else {
            setMapView(this.dataset.view);
          }
        });
      });
      
      // Inicializar opciones de sección (todas las disponibles)
      if (typeof populateSeccionOptions === 'function') populateSeccionOptions();
      $('copy-btn').addEventListener('click', copyDiscurso);
      
      setupDropzones();
      
      // Preset inicial
      applyPreset('morena-alianza');
      
      // Resize listener para SVG
      window.addEventListener('resize', function(){
        renderHistChart(currentDF === null ? 'macro' : 'micro');
        if (currentDF === null) renderCompareChart();
        if (macroMap1) macroMap1.invalidateSize();
        if (macroMap2) macroMap2.invalidateSize();
      });
      
      $('loading').style.display = 'none';
      $('root').style.display = 'block';
    } catch(e) { showError('Error en inicialización', e); }
  }

  function startInit() {
    // Esperar a que Leaflet esté disponible (puede tardar en sandboxes restrictivos)
    if (typeof L === 'undefined') {
      let waited = 0;
      const checker = setInterval(function(){
        waited += 100;
        if (typeof L !== 'undefined') {
          clearInterval(checker);
          init();
        } else if (waited > 15000) {
          clearInterval(checker);
          // En lugar de error fatal, inicializar sin Leaflet
          console.warn('Leaflet no se cargó en 15s. Continuando sin mapas...');
          window.L = window.L || null;
          init();
        }
      }, 100);
    } else {
      init();
    }
  }
  
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', startInit);
  else startInit();
})();
</script>
</body>
</html>
