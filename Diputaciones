  let macroMap2Layer = null;
  function renderMacroMapHeat(elecKey) {
    if (!macroMap2) return;
    if (macroMap2Layer) macroMap2.removeLayer(macroMap2Layer);
    macroMap2Layer = L.layerGroup();
    
    const DF_OBJ = [3,4,6,7,9,10,11,12,13,14,16,20];
    const DF_OBJ_SET = {3:1,4:1,6:1,7:1,9:1,10:1,11:1,12:1,13:1,14:1,16:1,20:1};
    const allBounds = [];
    
    function pctEnSeccion(d) {
      const e = getElec(d, elecKey);
      if (!e || e.vv === 0) return 0;
      let val = 0;
      if (macroMap2Filter === 'partidos') {
        let maxV = 0;
        PARTIES.forEach(function(p, idx){
          if (e.partidos[idx].solo > maxV) maxV = e.partidos[idx].solo;
        });
        val = maxV;
      } else {
        val = blockTotal(d, elecKey, blocks[1]);
      }
      return val/e.vv*100;
    }
    
    function colorEnSeccion(d) {
      const e = getElec(d, elecKey);
      if (!e || e.vv === 0) return '#5a6b8a';
      if (macroMap2Filter === 'partidos') {
        let maxV = 0, winP = null;
        PARTIES.forEach(function(p, idx){
          if (e.partidos[idx].solo > maxV) { maxV = e.partidos[idx].solo; winP = p; }
        });
        return winP ? PARTY_COLORS[winP] : '#5a6b8a';
      }
      return null;
    }
    
    function pctDelDistrito(df) {
      const pool = DATA.filter(function(d){return d[2] === df;});
      let bloqueTotal = 0, vvTotal = 0;
      let maxParty = 0, partyTotals = {};
      PARTIES.forEach(function(p){ partyTotals[p] = 0; });
      pool.forEach(function(d){
        const e = getElec(d, elecKey);
        if (!e || e.vv === 0) return;
        vvTotal += e.vv;
        bloqueTotal += blockTotal(d, elecKey, blocks[1]);
        PARTIES.forEach(function(p, idx){
          partyTotals[p] += e.partidos[idx].solo;
        });
      });
      if (vvTotal === 0) return 0;
      if (macroMap2Filter === 'partidos') {
        PARTIES.forEach(function(p){ if (partyTotals[p] > maxParty) maxParty = partyTotals[p]; });
        return maxParty/vvTotal*100;
      }
      return bloqueTotal/vvTotal*100;
    }
    
    function colorDelDistrito(df) {
      if (macroMap2Filter !== 'partidos') return null;
      const pool = DATA.filter(function(d){return d[2] === df;});
      let partyTotals = {};
      PARTIES.forEach(function(p){ partyTotals[p] = 0; });
      pool.forEach(function(d){
        const e = getElec(d, elecKey);
        if (!e) return;
        PARTIES.forEach(function(p, idx){
          partyTotals[p] += e.partidos[idx].solo;
        });
      });
      let maxV = 0, winP = null;
      PARTIES.forEach(function(p){ if (partyTotals[p] > maxV) { maxV = partyTotals[p]; winP = p; } });
      return winP ? PARTY_COLORS[winP] : '#5a6b8a';
    }
    
    let allVals = [];
    if (currentMacroView2 === 'distrito') {
      DF_OBJ.forEach(function(df){ allVals.push(pctDelDistrito(df)); });
    } else {
      const allSecs = DATA.filter(function(d){return DF_OBJ_SET[d[2]] && d[4] && d[5];});
      allSecs.forEach(function(d){ allVals.push(pctEnSeccion(d)); });
    }
    let maxPct = 0, minPct = 100;
    allVals.forEach(function(p){
      if (p > maxPct) maxPct = p;
      if (p < minPct && p > 0) minPct = p;
    });
    if (maxPct < 5) maxPct = 5;
    
    function heatColor(pct) {
      const range = maxPct - minPct;
      const ratio = range > 0 ? Math.max(0, Math.min(1, (pct - minPct) / range)) : 0.5;
      const stops = [
        [0.0, [180, 250, 180]],   // verde claro - potencial muy bajo
        [0.20, [255, 245, 130]],  // amarillo - bajo
        [0.45, [255, 165, 50]],   // naranja - medio
        [0.70, [220, 50, 30]],    // rojo - alto
        [1.0, [120, 20, 30]],     // guinda profundo - bastión
      ];
      let c1 = stops[0], c2 = stops[stops.length-1];
      for (let i=0; i<stops.length-1; i++) {
        if (ratio >= stops[i][0] && ratio <= stops[i+1][0]) {
          c1 = stops[i]; c2 = stops[i+1]; break;
        }
      }
      const localR = (ratio - c1[0]) / (c2[0] - c1[0]);
      const r = Math.round(c1[1][0] + (c2[1][0] - c1[1][0]) * localR);
      const g = Math.round(c1[1][1] + (c2[1][1] - c1[1][1]) * localR);
      const b = Math.round(c1[1][2] + (c2[1][2] - c1[1][2]) * localR);
      return 'rgb(' + r + ',' + g + ',' + b + ')';
    }
    
    const subEl = $('macro2-sub');
    if (subEl) {
      const viewLabel = currentMacroView2 === 'distrito' ? 'Por distrito completo' : 'Por sección electoral';
      subEl.textContent = viewLabel + ' · % del bloque ' + blockNames[1] + ' · Verde claro = bajo · Guinda = bastión';
    }
    
    if (currentMacroView2 === 'distrito') {
      // Contexto gris tenue
      Object.keys(SECTION_POLYS).forEach(function(secId){
        const coords = SECTION_POLYS[secId];
        if (!coords || coords.length < 3) return;
        const meta = SECTION_META[secId] || {};
        if (DF_OBJ_SET[meta.df]) return;
        const shape = L.polygon(coords, {
          color: '#2a3142', weight: 0.2, opacity: 0.4,
          fillColor: '#10141d', fillOpacity: 0.45
        });
        macroMap2Layer.addLayer(shape);
      });
      
      DF_OBJ.forEach(function(df){
        const pool = DATA.filter(function(d){return d[2] === df;});
        const pct = pctDelDistrito(df);
        const customColor = colorDelDistrito(df);
        const color = customColor !== null ? customColor : heatColor(pct);
        
        const distLabel = modoNivel === 'federal' ? 'Distrito Federal' : 'Distrito Local';
        const popupHtml = '<div style="font-family:sans-serif;font-size:12px;color:#000;font-weight:700;min-width:220px">' +
          '<div style="font-weight:800;color:#a01818;font-size:14px">' + distLabel + ' ' + df + '</div>' +
          '<hr style="border:none;border-top:1px solid #ccc;margin:6px 0">' +
          '<div style="font-size:22px;font-weight:800;color:' + color + '">' + pct.toFixed(2) + '%</div>' +
          '<div class="popup-enter-zone" style="margin-top:8px"><button class="popup-enter-btn" type="button" style="display:block;width:100%;padding:8px;background:#a01818;color:#fff;border:none;border-radius:4px;font-weight:800;cursor:pointer;font-size:11px;letter-spacing:0.5px">▸ VER DETALLE DEL DISTRITO</button></div>' +
          '</div>';
        
        // Pintar todas las secciones del distrito con el mismo color
        pool.forEach(function(d){
          const sec = d[0];
          const polyCoords = SECTION_POLYS[sec] || SECTION_POLYS[String(sec)];
          if (polyCoords && polyCoords.length >= 3) {
            const shape = L.polygon(polyCoords, {
              color: color, weight: 0, opacity: 0,
              fillColor: color, fillOpacity: 0.85
            });
            shape.bindPopup(popupHtml);
            wireEnterDist(shape, df);
            macroMap2Layer.addLayer(shape);
            polyCoords.forEach(function(p){ allBounds.push(p); });
          }
        });
        
        // (Borde dorado del distrito eliminado)
      });
    } else {
      Object.keys(SECTION_POLYS).forEach(function(secId){
        const coords = SECTION_POLYS[secId];
        if (!coords || coords.length < 3) return;
        const meta = SECTION_META[secId] || {};
        if (DF_OBJ_SET[meta.df]) return;
        
        const shape = L.polygon(coords, {
          color: '#2a3142', weight: 0.2, opacity: 0.4,
          fillColor: '#10141d', fillOpacity: 0.45
        });
        macroMap2Layer.addLayer(shape);
      });
      
      const allSecs = DATA.filter(function(d){return DF_OBJ_SET[d[2]] && d[4] && d[5];});
      allSecs.forEach(function(d){
        const pct = pctEnSeccion(d);
        const customColor = colorEnSeccion(d);
        const color = customColor !== null ? customColor : heatColor(pct);
        
        const sec = d[0];
        const polyCoords = SECTION_POLYS[sec] || SECTION_POLYS[String(sec)];
        const distLabel = modoNivel === 'federal' ? 'DF' : 'DL';
        const muniName = MUNIS[d[1]];
        
        const popupHtml = '<div style="font-family:sans-serif;font-size:12px;color:#000;font-weight:700;min-width:200px">' +
          '<div style="font-weight:800;color:#a01818;font-size:14px">Sección ' + String(d[0]).padStart(4,'0') + '</div>' +
          '<div style="margin-top:2px;font-size:11px;color:#000;font-weight:700">' + muniName + ' · ' + distLabel + ' ' + d[2] + '</div>' +
          '<hr style="border:none;border-top:1px solid #ccc;margin:6px 0">' +
