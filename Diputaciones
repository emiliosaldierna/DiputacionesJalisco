      blocks[3] = ['PAN','PRI','PRD'];
      blockNames[1] = 'SHHJ'; blockNames[2] = 'MC'; blockNames[3] = 'Frente PAN-PRI-PRD';
    } else if (name === 'morena-alianza') {
      blocks[1] = ['MORENA','PT','PVEM','HAGAMOS','FUTURO'];
      blocks[2] = ['MC'];
      blocks[3] = ['PAN','PRI','PRD'];
      blockNames[1] = 'MORENA + PT + PVEM + Hagamos + Futuro'; blockNames[2] = 'MC'; blockNames[3] = 'PAN + PRI + PRD';
