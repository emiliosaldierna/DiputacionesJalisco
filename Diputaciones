  function getElec(d, elecKey) {
    const o = ELEC_OFFSET_MAP[elecKey];
    if (o === undefined) return null;
    return {
      ln: d[o], tv: d[o+1], vv: d[o+2],
      partidos: PARTIES.map(function(p, i){
        return { name: p, solo: d[o + 3 + i] };
      }),
      combos: d[o + 12] || []  // [mask1, votos1, mask2, votos2, ...]
    };
  }

  function blockTotal(d, elecKey, blockIds) {
    const e = getElec(d, elecKey);
    if (!e) return 0;
    let total = 0;
    // Sumar votos solo de partidos del bloque
    let blockMask = 0;
    blockIds.forEach(function(p){
      const idx = PARTIES.indexOf(p);
      if (idx >= 0) {
        total += e.partidos[idx].solo;
        blockMask |= (1 << idx);
      }
    });
    // Sumar combos donde TODOS los partidos del combo estén en el bloque
    const negMask = ~blockMask;
    for (let j = 0; j < e.combos.length; j += 2) {
      const mask = e.combos[j];
      const votos = e.combos[j+1];
      if ((mask & negMask) === 0) {
        // todos los bits del mask están dentro de blockMask
        total += votos;
      }
    }
    return total;
  }
  
  // Para la vista por partido individual: contar solo + combos donde el partido esté
  function partyTotalConCombos(d, elecKey, partyIdx) {
    const e = getElec(d, elecKey);
    if (!e) return 0;
    let total = e.partidos[partyIdx].solo;
    const partyBit = 1 << partyIdx;
    for (let j = 0; j < e.combos.length; j += 2) {
      const mask = e.combos[j];
      const votos = e.combos[j+1];
      if ((mask & partyBit) !== 0) {
        // El partido está en el combo. Repartir proporcional al # de partidos del combo
        let nParts = 0;
        for (let k = 0; k < 9; k++) if (mask & (1<<k)) nParts++;
        total += votos / nParts;
      }
    }
    return total;
  }

  // Obtener key de elección desde tipo+año
  function getGlobalFilteredData() {
    let result = DATA;
    if (currentDFFilter) {
      const df = parseInt(currentDFFilter);
      result = result.filter(function(d){ return d[2] === df; });
    }
    if (currentSeccionFilter) {
      const sec = parseInt(currentSeccionFilter);
      result = result.filter(function(d){ return d[0] === sec; });
    }
    return result;
  }

  // Repoblar las opciones del selector de Sección según el distrito elegido
  function populateSeccionOptions() {
    const sel = document.getElementById('gf-seccion');
    if (!sel) return;
    const currentVal = sel.value;
    sel.innerHTML = '<option value="">Todas las secciones</option>';
    let pool = DATA;
    if (currentDFFilter) {
      const df = parseInt(currentDFFilter);
      pool = pool.filter(function(d){ return d[2] === df; });
    }
    // Ordenar secciones
    const secs = pool.map(function(d){ return d[0]; }).sort(function(a,b){ return a - b; });
    secs.forEach(function(sec){
      const o = document.createElement('option');
      o.value = sec;
      o.textContent = 'Sección ' + String(sec).padStart(4,'0');
      sel.appendChild(o);
    });
    // Restaurar selección si sigue siendo válida
    if (currentVal && secs.indexOf(parseInt(currentVal)) >= 0) {
      sel.value = currentVal;
    } else {
      currentSeccionFilter = '';
    }
  }

  function getCurrentElecKey() {
    const yrs = ELEC_YEARS[currentTipo];
    if (!yrs) return null;
    const found = yrs.find(function(y){return y.year === currentAnio;});
    return found ? found.key : null;
  }

  function loadData() {
    try {
      const txt = document.getElementById('dataset-script').textContent.trim();
      const obj = JSON.parse(txt);
      MUNIS = obj.munis;
      PARTIES = obj.parties;
      ELECS_LIST = obj.elecs;
      DATA = obj.rows;
      DF_WINNERS = obj.df_winners || {};  // legacy fallback
      DF_WIN = obj.ganadores_federales || {};
      DL_WIN = obj.ganadores_locales || {};
      POLYS = obj.polygons || {};
      
      // === Cargar polígonos por sección (cartografía real INE) ===
      try {
        const b64 = document.getElementById('section-polys-b64').textContent.trim();
        const bin = atob(b64);
        const bytes = new Uint8Array(bin.length);
        for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
        // Decompress síncronamente con ZLib via DecompressionStream
        const ds = new DecompressionStream('gzip');
        const stream = new Blob([bytes]).stream().pipeThrough(ds);
        new Response(stream).text().then(function(txt){
          const obj = JSON.parse(txt);
          // Nuevo formato: {polys: {...}, meta: {...}}
          // Compat: si es objeto plano con polígonos directamente
          if (obj.polys && obj.meta) {
            SECTION_POLYS = obj.polys;
            SECTION_META = obj.meta;
          } else {
            SECTION_POLYS = obj;
            SECTION_META = {};
          }
          console.log('Polígonos por sección cargados:', Object.keys(SECTION_POLYS).length);
          // Re-renderizar mapas que dependen de SECTION_POLYS
          // Mapa micro (vista distrito específico)
          if (typeof renderMap === 'function' && document.getElementById('map') && currentDF !== null) {
            renderMap();
          }
          // Mapas macro (vista inicial con los 12 distritos)
          const ek = (typeof getCurrentElecKey === 'function') ? getCurrentElecKey() : null;
          if (ek) {
            if (typeof renderMacroMapWinner === 'function' && macroMap1) renderMacroMapWinner(ek);
            if (typeof renderMacroMapHeat === 'function' && macroMap2) renderMacroMapHeat(ek);
          }
        }).catch(function(e){ console.warn('Error decodificando section polys:', e); });
      } catch(e) { console.warn('SECTION_POLYS decode failed:', e); }
      
      let off = 6;
      ELECS_LIST.forEach(function(e){
        ELEC_OFFSET_MAP[e[0]] = off;
        off += 13;  // v8: 3 base (ln,tv,vv) + 9 solos + 1 combos array = 13
      });
    } catch(e) { showError('Error decodificando datos', e); throw e; }
  }
  
  // Devuelve el ganador del distrito según el nivel activo (federal/local)
  function getWinner(d) {
    const src = modoNivel === 'federal' ? DF_WIN : DL_WIN;
    return src[d] || src[String(d)] || null;
  }

  // === CONFIG DEL FILTRO PRINCIPAL ===
  function updateAnioOptions() {
    const sel = $('gf-anio');
    sel.innerHTML = '';
    const yrs = ELEC_YEARS[currentTipo] || [];
    yrs.forEach(function(y){
      const opt = document.createElement('option');
