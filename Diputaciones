  // === MAPA MACRO 1: PARTIDO/BLOQUE GANADOR (puntos por sección + bordes de distrito) ===
  
  // === Helper para conectar polígonos del mapa con drill-down ===
  function wireEnterDist(layer, df) {
    layer.on('popupopen', function(e){
      try {
        var pop = e.popup.getElement();
        if (!pop) return;
        var btn = pop.querySelector('.popup-enter-btn');
        if (btn) {
          btn.onclick = function(ev){
            ev.preventDefault(); ev.stopPropagation();
            e.target.closePopup();
            enterDistrito(df);
          };
        }
      } catch(err){ console.warn('wireEnterDist error', err); }
    });
  }

  let macroMap1Layer = null;
  function renderMacroMapWinner(elecKey) {
    if (!macroMap1) return;
    if (macroMap1Layer) macroMap1.removeLayer(macroMap1Layer);
    macroMap1Layer = L.layerGroup();
    
    const DF_OBJ = [3,4,6,7,9,10,11,12,13,14,16,20];
    const DF_OBJ_SET = {3:1,4:1,6:1,7:1,9:1,10:1,11:1,12:1,13:1,14:1,16:1,20:1};
    const allBounds = [];
    
    if (currentMacroView1 === 'distrito') {
      // ============ MODO POR DISTRITO ============
      // Contexto: secciones fuera de los 12 distritos (gris tenue)
      Object.keys(SECTION_POLYS).forEach(function(secId){
        const coords = SECTION_POLYS[secId];
        if (!coords || coords.length < 3) return;
        const meta = SECTION_META[secId] || {};
        if (DF_OBJ_SET[meta.df]) return;
        const shape = L.polygon(coords, {
          color: '#2a3142', weight: 0.2, opacity: 0.4,
          fillColor: '#10141d', fillOpacity: 0.45
        });
        macroMap1Layer.addLayer(shape);
      });
      
      // Para cada distrito objetivo: calcular ganador y pintar TODAS sus secciones del mismo color
      DF_OBJ.forEach(function(df){
        const pool = DATA.filter(function(d){return d[2] === df;});
        
        let totals = {b1: 0, b2: 0, b3: 0};
        let partyTotals = {};
        PARTIES.forEach(function(p){ partyTotals[p] = 0; });
        
        pool.forEach(function(d){
          const e = getElec(d, elecKey);
          if (!e || e.vv === 0) return;
          totals.b1 += blockTotal(d, elecKey, blocks[1]);
          totals.b2 += blockTotal(d, elecKey, blocks[2]);
          totals.b3 += blockTotal(d, elecKey, blocks[3]);
          PARTIES.forEach(function(p, idx){
            partyTotals[p] += e.partidos[idx].solo;
          });
        });
        
        let color = '#5a6b8a', label = '';
        if (macroMap1Filter === 'partidos') {
          let maxV = 0, winP = null;
          PARTIES.forEach(function(p){
            if (partyTotals[p] > maxV) { maxV = partyTotals[p]; winP = p; }
          });
          if (winP) { color = PARTY_COLORS[winP]; label = winP; }
        } else {
          const max = Math.max(totals.b1, totals.b2, totals.b3);
          if (max > 0) {
            if (max === totals.b1) { color = BLOCK_COLORS[0]; label = blockNames[1]; }
            else if (max === totals.b2) { color = BLOCK_COLORS[1]; label = blockNames[2]; }
            else { color = BLOCK_COLORS[2]; label = blockNames[3]; }
          }
        }
        
        const totalVV = totals.b1 + totals.b2 + totals.b3;
        const distLabel = modoNivel === 'federal' ? 'Distrito Federal' : 'Distrito Local';
        const popupHtml = '<div style="font-family:sans-serif;font-size:12px;color:#000;font-weight:700;min-width:240px">' +
          '<div style="font-weight:800;color:#a01818;font-size:14px">' + distLabel + ' ' + df + '</div>' +
          '<div style="margin-top:2px;font-size:11px;color:#000;font-weight:700">' + pool.length + ' secciones</div>' +
          '<hr style="border:none;border-top:1px solid #ccc;margin:6px 0">' +
          '<div style="font-weight:800;color:' + color + ';font-size:13px">Ganador: ' + label + '</div>' +
          '<div style="margin-top:4px;color:#000;font-weight:700"><b style="color:#000">VV:</b> ' + totalVV.toLocaleString('es-MX') + '</div>' +
          '<div style="color:#000;font-weight:700"><b style="color:#000">' + blockNames[1] + ':</b> ' + (totalVV>0?(totals.b1/totalVV*100).toFixed(1):'0') + '%</div>' +
          '<div style="color:#000;font-weight:700"><b style="color:#000">' + blockNames[2] + ':</b> ' + (totalVV>0?(totals.b2/totalVV*100).toFixed(1):'0') + '%</div>' +
          '<div style="color:#000;font-weight:700"><b style="color:#000">' + blockNames[3] + ':</b> ' + (totalVV>0?(totals.b3/totalVV*100).toFixed(1):'0') + '%</div>' +
          '<div class="popup-enter-zone" style="margin-top:8px"><button class="popup-enter-btn" type="button" style="display:block;width:100%;padding:8px;background:#a01818;color:#fff;border:none;border-radius:4px;font-weight:800;cursor:pointer;font-size:11px;letter-spacing:0.5px">▸ VER DETALLE DEL DISTRITO</button></div>' +
          '</div>';
        
        // Pintar TODAS las secciones de este distrito con el color del distrito (sin bordes internos)
        pool.forEach(function(d){
          const sec = d[0];
          const polyCoords = SECTION_POLYS[sec] || SECTION_POLYS[String(sec)];
          if (polyCoords && polyCoords.length >= 3) {
            const shape = L.polygon(polyCoords, {
              color: color, weight: 0, opacity: 0,
              fillColor: color, fillOpacity: 0.85
            });
            shape.bindPopup(popupHtml);
            wireEnterDist(shape, df);
            macroMap1Layer.addLayer(shape);
