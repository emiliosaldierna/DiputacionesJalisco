      return { df: df, pct: tv>0 ? b1/tv*100 : 0 };
    }).sort(function(a,b){return b.pct - a.pct;});
    const rank = ranks.findIndex(function(r){return r.df === currentDF;}) + 1;
    
    let html = '<p style="margin-bottom:12px;color:var(--text-sec)"><span class="discurso-pill">RANKING #' + rank + ' DE 12</span> Frases para defender el ' + (modoNivel==="federal"?"Distrito Federal ":"Distrito Local ") + currentDF + ' ante la dirigencia. Análisis de <b>' + TIPO_LABELS[currentTipo] + ' ' + currentAnio + '</b>:</p>';
    if (blocks[1].length === 0) {
      html += '<div class="frase-bloque">⚠ Asigna primero los partidos al Bloque 1.</div>';
    } else {
      const b1Label = blockNames[1] + ' (' + blocks[1].join('+') + ')';
      // FRASE 1: usar el filtro actual (no hardcode Gobernador)
      html += '<div class="frase-bloque"><b>FRASE 1 · Fuerza de marca:</b><br>"En el ' + (modoNivel==="federal"?"Distrito Federal ":"Distrito Local ") + currentDF + ', en ' + TIPO_LABELS[currentTipo] + ' ' + currentAnio + ', ' + b1Label + ' alcanzó el <span class="num">' + dPct.toFixed(1) + '%</span> del voto. La marca está probada."</div>';
      if (brecha > 3) {
        html += '<div class="frase-bloque"><b>FRASE 2 · Pérdida de arrastre:</b><br>"En la boleta filtrada (' + TIPO_LABELS[currentTipo] + ' ' + currentAnio + ') capturamos solo <span class="num">' + dPct.toFixed(1) + '%</span> — brecha de <span class="num">' + brecha.toFixed(1) + 'pp</span> respecto a Gobernador. Son <span class="num">' + fmt(techo) + ' votos</span> que ya nos pertenecen pero no llegaron. Mi compromiso es cerrar esa brecha."</div>';
      }
      if (bastiones > 0) {
        html += '<div class="frase-bloque"><b>FRASE 3 · Piso seguro:</b><br>"Cuento con <span class="num">' + bastiones + ' secciones bastión</span> donde ' + blockNames[1] + ' ya gana con margen >15pp. Mi piso garantizado."</div>';
      }
      if (arrastre > 5) {
        html += '<div class="frase-bloque"><b>FRASE 4 · Recuperación:</b><br>"Hay <span class="num">' + arrastre + ' secciones</span> donde ganamos Gob pero perdimos esta boleta — voto cruzado recuperable."</div>';
      }
      if (estr > 0) {
        html += '<div class="frase-bloque"><b>FRASE 5 · El empujón:</b><br>"<span class="num">' + estr + ' secciones</span> se decidieron por menos de 5pp. Aquí mi perfil garantiza el triunfo."</div>';
      }
      let cierre = '';
      if (rank <= 3) cierre = 'Está entre los <b>3 distritos más viables</b>. Apostar por él es alta probabilidad.';
      else if (rank <= 6) cierre = 'En la <b>mitad superior</b> del ranking. Trabajable con inversión moderada.';
      else cierre = 'Requiere <b>esfuerzo táctico mayor</b>, pero con potencial de recuperación.';
