  function setMapStyle(styleId, target) {
    target = target || 'micro';
    const t = TILE_STYLES[styleId] || TILE_STYLES['google'];
    
    if (target === 'micro') {
      currentMapStyle = styleId;
      if (!map) return;
      if (tileLayer) map.removeLayer(tileLayer);
      tileLayer = L.tileLayer(t.url, { maxZoom: 20, attribution: t.attr, subdomains: t.sub });
      tileLayer.addTo(map);
    } else if (target === 'macro1') {
      macroMap1Style = styleId;
      if (!macroMap1) return;
      if (macroMap1Tile) macroMap1.removeLayer(macroMap1Tile);
      macroMap1Tile = L.tileLayer(t.url, { maxZoom: 20, attribution: t.attr, subdomains: t.sub });
      macroMap1Tile.addTo(macroMap1);
    } else if (target === 'macro2') {
      macroMap2Style = styleId;
      if (!macroMap2) return;
      if (macroMap2Tile) macroMap2.removeLayer(macroMap2Tile);
      macroMap2Tile = L.tileLayer(t.url, { maxZoom: 20, attribution: t.attr, subdomains: t.sub });
      macroMap2Tile.addTo(macroMap2);
    }
    
    // Update active button only for the relevant target
    document.querySelectorAll('.mss-btn').forEach(function(b){
      const bTarget = b.dataset.target || 'micro';
      if (bTarget === target) {
        b.classList.toggle('active', b.dataset.style === styleId);
      }
    });
  }

