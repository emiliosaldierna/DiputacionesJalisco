          svg += '<rect x="' + PAD_L + '" y="' + yCursor + '" width="' + w + '" height="' + barH + '" fill="' + e.color + '" opacity="' + op + '"><title>' + e.name + ': ' + e.pct.toFixed(2) + '%</title></rect>';
          const labelStyle = r === 0 ? 'font-weight:800' : 'font-weight:700;opacity:0.85';
          if (w > 90) {
            svg += '<text x="' + (PAD_L + 6) + '" y="' + (yCursor + 13) + '" class="cc-label" style="fill:white;font-size:10px;' + labelStyle + '">' + RANK_LABELS[r] + ' ' + e.short + '</text>';
          } else {
            svg += '<text x="' + (PAD_L + w + 4) + '" y="' + (yCursor + 13) + '" class="cc-label" style="fill:' + e.color + ';font-size:10px;' + labelStyle + '">' + RANK_LABELS[r] + ' ' + e.short + '</text>';
          }
