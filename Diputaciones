  // === GRÁFICA HISTÓRICA (SVG custom) ===
  function renderHistChart(scope) {
    const isMicro = scope === 'micro';
    const tipo = isMicro ? currentHistMicroTipo : currentHistTipo;
    const mode = isMicro ? currentHistMicroMode : currentHistMode;
    const containerId = isMicro ? 'hist-micro-chart' : 'hist-chart';
    const legendId = isMicro ? 'hist-micro-legend' : 'hist-legend';
    const hidden = isMicro ? hiddenLinesMicro : hiddenLines;
    
    const yrs = ELEC_YEARS[tipo] || [];
    if (yrs.length === 0) {
      $(containerId).innerHTML = '<div style="text-align:center;padding:30px;color:var(--text-tri)">Sin datos históricos</div>';
      return;
    }
    
    // Dataset: macro = todos los 12 distritos, micro = solo el actual
    const pool = isMicro ? DATA.filter(function(d){return d[2] === currentDF;}) : DATA;
    
    // Para cada año, calcular % por bloque o por partido
    // Series: lista de objetos {name, color, points: [{year, pct}]}
    const sortedYrs = yrs.slice().sort(function(a,b){return parseInt(a.year) - parseInt(b.year);});
    
    let series = [];
    if (mode === 'bloques') {
      const blockData = [
        { name: blockNames[1], color: BLOCK_COLORS[0], blockId: 1 },
        { name: blockNames[2], color: BLOCK_COLORS[1], blockId: 2 },
        { name: blockNames[3], color: BLOCK_COLORS[2], blockId: 3 },
      ];
      blockData.forEach(function(bd){
        if (blocks[bd.blockId].length === 0) return;
        const pts = sortedYrs.map(function(y){
          let totalVV = 0, blockV = 0;
          pool.forEach(function(d){
            const e = getElec(d, y.key); if (!e) return;
            totalVV += e.vv;
            blockV += blockTotal(d, y.key, blocks[bd.blockId]);
          });
          return { year: y.year, pct: totalVV>0 ? blockV/totalVV*100 : 0 };
        });
        series.push({ name: bd.name, color: bd.color, points: pts });
      });
    } else {
      // Por partidos: top partidos del año más reciente
      const latestKey = sortedYrs[sortedYrs.length-1].key;
      const partyTotals = PARTIES.map(function(p, i){
        let v = 0;
        pool.forEach(function(d){ const e = getElec(d, latestKey); if (e) v += e.partidos[i].solo; });
        return { name: p, votes: v };
      }).sort(function(a,b){return b.votes - a.votes;});
      
      // Top 6 partidos para no saturar
      const topParties = partyTotals.slice(0, 6).map(function(p){return p.name;});
      
      topParties.forEach(function(p){
        const pIdx = PARTIES.indexOf(p);
        const pts = sortedYrs.map(function(y){
          let totalVV = 0, partyV = 0;
          pool.forEach(function(d){
            const e = getElec(d, y.key); if (!e) return;
            totalVV += e.vv;
            partyV += e.partidos[pIdx].solo;
          });
          return { year: y.year, pct: totalVV>0 ? partyV/totalVV*100 : 0 };
        });
        series.push({ name: p, color: PARTY_COLORS[p], points: pts });
      });
    }
    
    drawSVGChart(containerId, sortedYrs, series, hidden);
    drawHistLegend(legendId, series, hidden, scope);
  }

  function drawSVGChart(containerId, years, series, hidden) {
    const container = $(containerId);
    const W = container.clientWidth || 600;
    const H = 320;
    const PAD_L = 50, PAD_R = 20, PAD_T = 20, PAD_B = 40;
    const innerW = W - PAD_L - PAD_R;
    const innerH = H - PAD_T - PAD_B;
    
    // Y range
    let maxY = 0;
    series.forEach(function(s){
      if (hidden.has(s.name)) return;
      s.points.forEach(function(p){ if (p.pct > maxY) maxY = p.pct; });
    });
    maxY = Math.ceil((maxY + 5) / 10) * 10;
    if (maxY < 20) maxY = 20;
    
    const xStep = years.length > 1 ? innerW / (years.length - 1) : 0;
    const xAt = function(i){ return PAD_L + i * xStep; };
    const yAt = function(v){ return PAD_T + innerH - (v / maxY) * innerH; };
    
    let svg = '<svg viewBox="0 0 ' + W + ' ' + H + '" preserveAspectRatio="xMidYMid meet">';
    
    // Grid
    for (let i = 0; i <= 5; i++) {
      const v = (maxY / 5) * i;
      const y = yAt(v);
      svg += '<line x1="' + PAD_L + '" y1="' + y + '" x2="' + (W-PAD_R) + '" y2="' + y + '" class="hist-grid"/>';
      svg += '<text x="' + (PAD_L-6) + '" y="' + (y+3) + '" text-anchor="end" class="hist-axis-label">' + v.toFixed(0) + '%</text>';
    }
    
    // X axis labels
    years.forEach(function(y, i){
      const x = xAt(i);
      svg += '<text x="' + x + '" y="' + (H-PAD_B+18) + '" text-anchor="middle" class="hist-axis-label" style="font-size:11px;font-weight:700;fill:var(--text-pri)">' + y.year + '</text>';
    });
    
    // Lines and dots
    series.forEach(function(s){
      if (hidden.has(s.name)) return;
      let path = '';
      s.points.forEach(function(p, i){
        const x = xAt(i);
        const y = yAt(p.pct);
        if (i === 0) path += 'M' + x + ',' + y;
        else path += ' L' + x + ',' + y;
      });
      svg += '<path d="' + path + '" class="hist-line" stroke="' + s.color + '"/>';
      
      // Dots
      s.points.forEach(function(p, i){
        const x = xAt(i);
        const y = yAt(p.pct);
        svg += '<circle cx="' + x + '" cy="' + y + '" r="4" fill="' + s.color + '" stroke="#0a0e1a" stroke-width="2"/>';
        // Label
        svg += '<text x="' + x + '" y="' + (y-10) + '" text-anchor="middle" style="font-size:10px;font-weight:700;fill:' + s.color + '">' + p.pct.toFixed(1) + '</text>';
      });
    });
    
    svg += '</svg>';
    container.innerHTML = svg;
  }

  function drawHistLegend(legendId, series, hidden, scope) {
    let html = '';
    series.forEach(function(s){
      const op = hidden.has(s.name) ? 'disabled' : '';
      html += '<div class="hist-legend-item ' + op + '" data-series="' + s.name + '" data-scope="' + scope + '"><span class="hist-legend-dot" style="background:' + s.color + '"></span><b>' + s.name + '</b></div>';
    });
    $(legendId).innerHTML = html;
    document.querySelectorAll('#' + legendId + ' .hist-legend-item').forEach(function(item){
      item.addEventListener('click', function(){
        const name = item.dataset.series;
        const sc = item.dataset.scope;
        const target = sc === 'micro' ? hiddenLinesMicro : hiddenLines;
        if (target.has(name)) target.delete(name);
        else target.add(name);
        renderHistChart(sc);
      });
    });
  }

  // === MICRO ===
  function enterDistrito(df) {
    currentDF = df;
    populateMicroFilters();
    renderAll();  // primero render para que vista-micro tenga display:block
    
    // Después: inicializar mapa cuando el contenedor tenga dimensiones reales
    function initMicroMap() {
      const c = document.getElementById('map');
      if (!c || typeof L === 'undefined') {
        setTimeout(initMicroMap, 100);
        return;
      }
      // Verificar que el contenedor tenga dimensiones (vista-micro ya visible)
      if (c.offsetWidth === 0 || c.offsetHeight === 0) {
        setTimeout(initMicroMap, 100);
        return;
      }
      try {
        if (!map) initMap();
        if (map) {
          map.invalidateSize();
          renderMap();  // re-render mapa con datos del distrito actual
        }
      } catch(e) {
        console.error('Error init micro map:', e);
      }
    }
    setTimeout(initMicroMap, 100);
  }

