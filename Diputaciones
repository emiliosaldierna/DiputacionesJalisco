<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Centro de Inteligencia Estratégica · MORENA · Diputación Local</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg-0: #050810; --bg-1: #0a0e1a; --bg-2: #0f1525; --bg-3: #141c2f;
  --border: rgba(140, 180, 240, 0.12);
  --text-pri: #e8f0ff; --text-sec: #8fa3c7; --text-tri: #5a6b8a;
  --morena: #a01818; --gold: #ffb13b; --green: #2dffaa; --red: #ff2d4f; --cyan: #00f0ff; --purple: #b14eff;
  --b1: #a01818; --b2: #ff8c00; --b3: #1a5fb4; --bn: #5a6b8a;
}
body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background: linear-gradient(180deg, #050810 0%, #0a0e1a 50%, #050810 100%);
  background-attachment: fixed;
  color: var(--text-pri);
  min-height: 100vh;
  padding: 14px;
  font-size: 13px;
}
.container { max-width: 1400px; margin: 0 auto; }

.header {
  background: linear-gradient(135deg, rgba(160,24,24,0.1), rgba(0,240,255,0.04));
  border: 1px solid rgba(160,24,24,0.4);
  border-radius: 10px;
  padding: 16px 20px;
  margin-bottom: 16px;
  position: relative;
  overflow: hidden;
}
.header::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, var(--morena) 0%, var(--gold) 50%, var(--morena) 100%);
  animation: scan 4s linear infinite;
}
@keyframes scan { 0%,100% { opacity: 0.4; } 50% { opacity: 1; } }
.brand-row { display: flex; align-items: center; gap: 12px; margin-bottom: 6px; }
.brand-icon {
  width: 38px; height: 38px;
  background: radial-gradient(circle, var(--morena) 0%, transparent 70%);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px;
  box-shadow: 0 0 24px rgba(160,24,24,0.5);
}
.brand-title {
  font-size: 16px; font-weight: 800; letter-spacing: 1.5px;
  text-transform: uppercase; color: var(--gold);
  text-shadow: 0 0 14px rgba(255,177,59,0.4);
}
.brand-sub { font-size: 10px; color: var(--text-tri); letter-spacing: 0.5px; }

/* FILTRO PRINCIPAL DE ELECCIÓN/AÑO */
.global-filter {
  background: linear-gradient(135deg, rgba(255,177,59,0.08), rgba(0,240,255,0.04));
  border: 1px solid rgba(255,177,59,0.3);
  border-radius: 8px;
  padding: 12px 16px;
  margin-bottom: 14px;
}
.gf-title { font-size: 10px; color: var(--gold); letter-spacing: 2px; text-transform: uppercase; font-weight: 700; margin-bottom: 8px; }
.gf-row { display: flex; gap: 10px; align-items: end; flex-wrap: wrap; }
.gf-block { flex: 1; min-width: 150px; }
.gf-block label { font-size: 9px; color: var(--text-tri); letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 4px; }
.gf-block select {
  width: 100%; padding: 8px 10px;
  background: rgba(5,8,16,0.8); border: 1px solid rgba(255,177,59,0.3);
  border-radius: 5px; color: var(--text-pri); font-size: 13px; font-weight: 700;
  font-family: inherit; cursor: pointer;
}
.gf-block select:focus { outline: none; border-color: var(--gold); box-shadow: 0 0 0 2px rgba(255,177,59,0.15); }

.breadcrumb {
  background: rgba(15,21,37,0.7);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 8px 14px;
  margin-bottom: 14px;
  font-size: 11px;
  color: var(--text-sec);
  display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
}
.bc-link { color: var(--cyan); cursor: pointer; font-weight: 700; text-decoration: underline; }
.bc-link:hover { color: var(--gold); }
.bc-current { color: var(--gold); font-weight: 700; }
.bc-arrow { color: var(--text-tri); }

.panel {
  background: linear-gradient(180deg, rgba(15,21,37,0.85), rgba(10,14,26,0.9));
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 14px 16px;
  margin-bottom: 14px;
}
.panel-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 12px; flex-wrap: wrap; gap: 8px; }
.panel-title {
  font-size: 12px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--cyan);
}
.panel-sub { font-size: 9px; color: var(--text-tri); letter-spacing: 0.5px; }

/* BUILDER DE BLOQUES */
.block-builder {
  background: linear-gradient(135deg, rgba(177,78,255,0.08), rgba(0,240,255,0.04));
  border: 1px solid rgba(177,78,255,0.3);
  border-radius: 8px;
  padding: 14px 16px;
  margin-bottom: 14px;
}
.block-builder-title {
  font-size: 11px; color: var(--purple); letter-spacing: 2px; text-transform: uppercase;
  font-weight: 700; margin-bottom: 4px;
}
.block-builder-sub { font-size: 10px; color: var(--text-sec); margin-bottom: 12px; }

.parties-pool {
  display: flex; flex-wrap: wrap; gap: 6px;
  padding: 10px;
  background: rgba(5,8,16,0.5);
  border: 1px dashed rgba(140,180,240,0.2);
  border-radius: 6px;
  margin-bottom: 12px;
  min-height: 50px;
}
.parties-pool-label { width: 100%; font-size: 9px; color: var(--text-tri); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px; }
.party-chip {
  padding: 5px 10px;
  background: rgba(5,8,16,0.7); border: 1px solid var(--text-tri);
  color: var(--text-pri); border-radius: 4px;
  font-size: 11px; font-weight: 700; cursor: grab;
  transition: all 0.15s;
  user-select: none;
  display: inline-flex; align-items: center; gap: 6px;
}
.party-chip:hover { transform: scale(1.05); }
.party-chip.drag { opacity: 0.4; }
.party-chip-votes { font-size: 9px; color: var(--text-tri); font-weight: 600; }

.blocks-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px;
}
.block-zone {
  border-radius: 6px; padding: 10px;
  min-height: 90px;
  border: 2px dashed transparent;
  transition: all 0.15s;
}
.block-zone.b1 { background: rgba(160,24,24,0.08); border-color: rgba(160,24,24,0.4); }
.block-zone.b2 { background: rgba(255,140,0,0.08); border-color: rgba(255,140,0,0.4); }
.block-zone.b3 { background: rgba(26,95,180,0.08); border-color: rgba(26,95,180,0.4); }
.block-zone.dragover { border-style: solid; border-width: 2px; transform: scale(1.02); }
.block-zone.b1.dragover { background: rgba(160,24,24,0.15); }
.block-zone.b2.dragover { background: rgba(255,140,0,0.15); }
.block-zone.b3.dragover { background: rgba(26,95,180,0.15); }

.block-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
.block-name {
  font-size: 9px; letter-spacing: 1px; text-transform: uppercase; font-weight: 700;
  flex: 1;
  background: transparent; border: none; color: inherit;
  font-family: inherit;
  outline: none;
  border-bottom: 1px dotted transparent;
  padding: 2px 4px;
  cursor: text;
}
.block-name:hover, .block-name:focus { border-bottom-color: currentColor; }
.b1 .block-name { color: var(--b1); }
.b2 .block-name { color: var(--b2); }
.b3 .block-name { color: var(--b3); }
.block-stats { font-size: 9px; color: var(--text-sec); font-variant-numeric: tabular-nums; text-align: right; }
.block-pct { font-size: 14px; font-weight: 800; }
.b1 .block-pct { color: var(--b1); }
.b2 .block-pct { color: var(--b2); }
.b3 .block-pct { color: var(--b3); }

.bb-actions { display: flex; gap: 8px; margin-top: 12px; flex-wrap: wrap; }
.bb-btn {
  padding: 6px 12px; background: rgba(0,240,255,0.08); color: var(--cyan);
  border: 1px solid rgba(0,240,255,0.3); border-radius: 5px; cursor: pointer;
  font-family: inherit; font-size: 10px; font-weight: 700; letter-spacing: 0.5px;
}
.bb-btn:hover { background: rgba(0,240,255,0.15); }
.bb-btn.preset { background: rgba(255,177,59,0.08); color: var(--gold); border-color: rgba(255,177,59,0.3); }
.bb-btn.preset:hover { background: rgba(255,177,59,0.15); }

.discurso {
  background: linear-gradient(135deg, rgba(160,24,24,0.06), rgba(255,177,59,0.04));
  border: 1px solid rgba(160,24,24,0.3);
  border-left: 4px solid var(--morena);
  border-radius: 8px;
  padding: 16px 20px;
  margin-bottom: 14px;
  font-size: 12px;
  line-height: 1.7;
}
.discurso-title {
  font-size: 11px; color: var(--gold); letter-spacing: 2px; text-transform: uppercase;
  font-weight: 700; margin-bottom: 12px;
}
.discurso-pill {
  display: inline-block; padding: 2px 8px; background: rgba(45,255,170,0.1);
  color: var(--green); border-radius: 3px; font-size: 9px; font-weight: 700;
  letter-spacing: 1px; margin-right: 6px; vertical-align: middle;
}
.frase-bloque {
  background: rgba(5,8,16,0.4); border-left: 3px solid var(--gold);
  padding: 10px 14px; margin: 10px 0;
  font-style: italic; color: var(--text-pri);
  border-radius: 0 5px 5px 0;
}
.frase-bloque b { color: var(--gold); font-style: normal; }
.frase-bloque .num { color: var(--green); font-weight: 800; font-style: normal; font-size: 13px; }

/* RANKING DISTRITAL TABLA */
.ranking-table { width: 100%; border-collapse: collapse; font-size: 11px; margin-top: 12px; }
.ranking-table th {
  background: rgba(5,8,16,0.6); color: var(--cyan);
  padding: 8px 10px; text-align: left; font-size: 9px;
  letter-spacing: 1px; text-transform: uppercase;
  border-bottom: 1px solid var(--cyan);
}
.ranking-table td {
  padding: 8px 10px; border-bottom: 1px solid rgba(140,180,240,0.08);
  font-variant-numeric: tabular-nums;
}
.ranking-table tr { cursor: pointer; transition: background 0.15s; }
.ranking-table tr:hover { background: rgba(0,240,255,0.05); }
.rt-rank { font-weight: 800; color: var(--gold); font-family: 'Courier New', monospace; }
.rt-bar { width: 100px; height: 8px; background: rgba(5,8,16,0.6); border-radius: 4px; overflow: hidden; display: inline-block; vertical-align: middle; margin-left: 8px; }
.rt-bar-fill { height: 100%; background: linear-gradient(90deg, var(--morena), var(--gold)); }

/* PARTY GRID */
.party-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
  gap: 8px;
}
.party-card-sm {
  background: rgba(5,8,16,0.6); border: 1px solid var(--border); border-radius: 6px;
  padding: 10px; position: relative; overflow: hidden;
}
.party-card-sm.rank1 { border-color: var(--green); background: linear-gradient(135deg, rgba(45,255,170,0.08), rgba(5,8,16,0.7)); }
.party-card-sm.rank2 { border-color: var(--gold); background: linear-gradient(135deg, rgba(255,177,59,0.05), rgba(5,8,16,0.7)); }
.party-card-sm.rank3 { border-color: var(--morena); background: linear-gradient(135deg, rgba(160,24,24,0.05), rgba(5,8,16,0.7)); }
.pcs-rank { position: absolute; top: 6px; right: 8px; font-size: 9px; color: var(--text-tri); font-weight: 800; }
.pcs-name { font-size: 12px; font-weight: 800; margin-bottom: 4px; }
.pcs-pct { font-size: 18px; font-weight: 800; font-variant-numeric: tabular-nums; }
.pcs-votes { font-size: 9px; color: var(--text-sec); font-variant-numeric: tabular-nums; }
.pcs-bar { height: 4px; background: rgba(5,8,16,0.6); border-radius: 2px; margin-top: 6px; overflow: hidden; }
.pcs-bar-fill { height: 100%; }

/* HISTORICAL CHART (custom SVG) */
.hist-panel {
  background: linear-gradient(180deg, rgba(15,21,37,0.9), rgba(10,14,26,0.95));
  border: 1px solid rgba(0,240,255,0.2);
  border-radius: 8px;
  padding: 14px 16px;
  margin-bottom: 14px;
}
.hist-controls { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; margin-bottom: 12px; }
.hist-controls label { font-size: 9px; color: var(--text-tri); letter-spacing: 1px; text-transform: uppercase; }
.hist-controls select {
  padding: 5px 8px; background: rgba(5,8,16,0.8); border: 1px solid rgba(0,240,255,0.3);
  border-radius: 4px; color: var(--text-pri); font-size: 11px; font-weight: 700;
  font-family: inherit; cursor: pointer;
}
.hist-toggle { display: flex; gap: 2px; }
.hist-toggle-btn {
  padding: 5px 10px; background: rgba(5,8,16,0.6); color: var(--text-sec);
  border: 1px solid var(--border); border-radius: 4px; cursor: pointer;
  font-family: inherit; font-size: 10px; font-weight: 700; letter-spacing: 0.5px;
}
.hist-toggle-btn.active { background: rgba(0,240,255,0.15); color: var(--cyan); border-color: var(--cyan); }

.hist-chart { width: 100%; height: 320px; position: relative; }
.hist-chart svg { width: 100%; height: 100%; }
.hist-axis-label { font-size: 10px; fill: var(--text-tri); }
.hist-grid { stroke: rgba(140,180,240,0.08); stroke-width: 1; }
.hist-line { fill: none; stroke-width: 2.5; transition: stroke-width 0.15s; }
.hist-line.hover { stroke-width: 4; }
.hist-dot { stroke-width: 2; }
.hist-legend { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 8px; padding-top: 8px; border-top: 1px solid var(--border); font-size: 10px; }
.hist-legend-item { display: flex; align-items: center; gap: 6px; cursor: pointer; transition: opacity 0.15s; }
.hist-legend-item.disabled { opacity: 0.3; }
.hist-legend-dot { width: 12px; height: 12px; border-radius: 2px; }

/* MICRO */
.micro-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 14px; }
.ms-card { background: rgba(15,21,37,0.7); border: 1px solid var(--border); border-radius: 6px; padding: 10px 12px; }
.ms-label { font-size: 9px; color: var(--text-tri); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px; }
.ms-value { font-size: 18px; font-weight: 800; color: var(--gold); font-variant-numeric: tabular-nums; }
.ms-delta { font-size: 9px; color: var(--text-sec); margin-top: 2px; }

.layer-selector {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px;
  margin-bottom: 14px;
  background: rgba(15,21,37,0.7); border: 1px solid var(--border); border-radius: 8px; padding: 8px;
}
.layer-btn {
  background: rgba(5,8,16,0.6); border: 1px solid rgba(140,180,240,0.15);
  color: var(--text-sec); padding: 10px 8px; border-radius: 5px; cursor: pointer;
  font-family: inherit; font-size: 11px; font-weight: 600; letter-spacing: 0.5px;
  transition: all 0.2s; text-align: center;
}
.layer-btn:hover { background: rgba(160,24,24,0.05); color: var(--text-pri); }
.mapview-btn.active {
  background: rgba(160,24,24,0.35) !important;
  color: var(--text-pri) !important;
  border-color: var(--red) !important;
  box-shadow: 0 0 12px rgba(160,24,24,0.4);
}
.layer-btn.active {
  background: linear-gradient(135deg, rgba(160,24,24,0.2), rgba(255,177,59,0.1));
  color: var(--gold); border-color: var(--morena);
  box-shadow: 0 0 14px rgba(160,24,24,0.3) inset;
}
.layer-icon { font-size: 16px; display: block; margin-bottom: 3px; }

.grid-2 { display: grid; grid-template-columns: 1.4fr 1fr; gap: 14px; margin-bottom: 14px; }

#map { height: 480px; border-radius: 6px; background: #0a0e1a; border: 1px solid var(--border); }
@media (max-width: 900px) { #map { height: 360px; } }

.legend {
  display: flex; flex-wrap: wrap; gap: 8px;
  padding: 8px 10px; margin-top: 8px;
  background: rgba(5,8,16,0.6); border: 1px solid var(--border);
  border-radius: 6px; font-size: 10px;
}
.legend-item { display: flex; align-items: center; gap: 5px; }
.legend-dot { width: 12px; height: 12px; border-radius: 3px; }

.btn-back {
  background: rgba(0,240,255,0.1); color: var(--cyan);
  border: 1px solid rgba(0,240,255,0.3); padding: 8px 14px;
  border-radius: 5px; cursor: pointer; font-family: inherit; font-size: 11px;
  font-weight: 700; letter-spacing: 0.5px; margin-bottom: 12px;
}
.btn-back:hover { background: rgba(0,240,255,0.2); }

.copy-btn {
  background: rgba(255,140,0,0.1); color: var(--gold);
  border: 1px solid rgba(255,140,0,0.3); padding: 8px 14px;
  border-radius: 5px; cursor: pointer; font-family: inherit; font-size: 10px;
  font-weight: 700; letter-spacing: 0.5px; margin-top: 12px;
}
.copy-btn:hover { background: rgba(255,140,0,0.2); }

.filters-micro {
  background: rgba(15,21,37,0.7); border: 1px solid var(--border);
  border-radius: 8px; padding: 10px; margin-bottom: 14px;
  display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px;
}
.filter-block label { font-size: 9px; color: var(--text-tri); letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 4px; }
.filter-block select {
  width: 100%; padding: 8px;
  background: rgba(5,8,16,0.8); border: 1px solid rgba(160,24,24,0.3);
  border-radius: 5px; color: var(--text-pri); font-size: 12px; font-weight: 600;
  font-family: inherit; cursor: pointer;
}

/* ANÁLISIS DEL CANDIDATO */
.cand-panel {
  background: linear-gradient(135deg, rgba(123,31,162,0.08), rgba(160,24,24,0.08));
  border: 2px solid rgba(177,78,255,0.4);
  border-radius: 10px;
  padding: 20px 22px;
  margin-bottom: 18px;
}
.cand-title {
  font-size: 14px; color: var(--purple); letter-spacing: 2px; text-transform: uppercase;
  font-weight: 800; margin-bottom: 4px;
}
.cand-sub {
  font-size: 11px; color: var(--text-sec); margin-bottom: 16px;
}
.cand-conclusion {
  background: rgba(160,24,24,0.1);
  border-left: 4px solid var(--morena);
  padding: 12px 16px;
  border-radius: 0 8px 8px 0;
  margin-bottom: 12px;
  font-size: 12px;
  line-height: 1.6;
}
.cand-conclusion b { color: var(--gold); }
.cand-conclusion .num { color: var(--green); font-weight: 800; }
.cand-conclusion .danger { color: var(--red); font-weight: 800; }
.cand-table {
  width: 100%; border-collapse: collapse;
  font-size: 11px; margin-top: 12px;
}
.cand-table th, .cand-table td {
  padding: 8px 10px; text-align: right;
  border: 1px solid var(--border);
  font-variant-numeric: tabular-nums;
}
.cand-table th {
  background: rgba(5,8,16,0.95);
  color: var(--gold);
  text-transform: uppercase;
  font-size: 9px;
  letter-spacing: 1px;
}
.cand-table td:nth-child(-n+2) {
  text-align: left;
  background: rgba(5,8,16,0.6);
}
.cand-table tr.winner-row td {
  background: rgba(45,255,170,0.08);
}
.cand-table .danger {
  color: var(--red);
  font-weight: 800;
}
.cand-table .win {
  color: var(--green);
  font-weight: 800;
}

/* MAPAS MACRO (vista distrital con google maps) */
.macro-map-panel {
  background: linear-gradient(180deg, rgba(15,21,37,0.85), rgba(10,14,26,0.9));
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 14px 16px;
  margin-bottom: 14px;
}
.macro-map-container { height: 480px; border-radius: 6px; background: #0a0e1a; border: 1px solid var(--border); }
@media (max-width: 900px) { .macro-map-container { height: 360px; } }

/* GRÁFICA COMPARATIVA BARRAS FED VS LOCAL */
.compare-chart-panel {
  background: linear-gradient(180deg, rgba(15,21,37,0.9), rgba(10,14,26,0.95));
  border: 1px solid rgba(177,78,255,0.3);
  border-radius: 8px;
  padding: 16px 18px;
  margin-bottom: 14px;
}
.compare-chart-controls {
  display: flex; gap: 12px; align-items: center; flex-wrap: wrap; margin-bottom: 12px;
}
.compare-chart-controls label {
  font-size: 9px; color: var(--text-tri); letter-spacing: 1px; text-transform: uppercase;
}
.compare-chart-controls select {
  padding: 5px 8px; background: rgba(5,8,16,0.8); border: 1px solid rgba(177,78,255,0.3);
  border-radius: 4px; color: var(--text-pri); font-size: 11px; font-weight: 700;
  font-family: inherit; cursor: pointer;
}
.compare-chart {
  width: 100%; min-height: 380px;
}
.compare-chart svg { width: 100%; display: block; }
.cc-bar-fed { fill: var(--gold); }
.cc-bar-loc { fill: var(--cyan); }
.cc-label { font-size: 10px; fill: var(--text-pri); font-weight: 600; }
.cc-label-pct { font-size: 9px; font-weight: 700; }
.cc-axis { stroke: rgba(140,180,240,0.15); stroke-width: 1; }
.cc-axis-text { font-size: 9px; fill: var(--text-tri); }
.cc-legend {
  display: flex; gap: 14px; margin-top: 8px; padding-top: 8px;
  border-top: 1px solid var(--border); font-size: 11px; color: var(--text-sec);
}
.cc-legend-item { display: flex; align-items: center; gap: 6px; }
.cc-legend-swatch { width: 14px; height: 14px; border-radius: 3px; }

/* SELECTOR DE ESTILO DE MAPA */
.map-style-selector {
  display: flex; gap: 4px; margin-bottom: 8px;
}
.mss-btn {
