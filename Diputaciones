      sel.value = currentAnio;
    }
  }

  // === BUILDER ===
  function getAssignedParties() {
    const a = new Set();
    [1,2,3].forEach(function(b){ blocks[b].forEach(function(p){a.add(p);}); });
    return a;
  }

  function getCurrentDataset() {
    let result = DATA;
    // Aplicar filtros globales (sección y distrito desde el filtro principal)
    if (currentSeccionFilter) {
      const sec = parseInt(currentSeccionFilter);
      return result.filter(function(d){ return d[0] === sec; });
    }
    if (currentDF !== null) {
      return result.filter(function(d){ return d[2] === currentDF; });
    }
    if (currentDFFilter) {
      const df = parseInt(currentDFFilter);
      return result.filter(function(d){ return d[2] === df; });
    }
    return result;
  }

  function getDLFilter() {
    const dl = $('f-dl') ? $('f-dl').value : '';
    const muni = $('f-muni') ? $('f-muni').value : '';
    let pool = getCurrentDataset();
    if (dl) pool = pool.filter(function(d){return d[3] == dl;});
    if (muni) pool = pool.filter(function(d){return MUNIS[d[1]] === muni;});
    return pool;
  }

  function renderBuilder() {
    const elecKey = getCurrentElecKey();
    if (!elecKey) return;
    const assigned = getAssignedParties();
    const dataset = getCurrentDataset();
    let totalVV = 0;
    dataset.forEach(function(d){ const e = getElec(d, elecKey); if (e) totalVV += e.vv; });
    
    let poolHtml = '<div class="parties-pool-label">Partidos sin asignar</div>';
    PARTIES.forEach(function(p) {
      if (assigned.has(p)) return;
      let votes = 0;
      const idx = PARTIES.indexOf(p);
      dataset.forEach(function(d){ const e = getElec(d, elecKey); if (e) votes += e.partidos[idx].solo; });
      const pct = totalVV > 0 ? votes/totalVV*100 : 0;
      poolHtml += '<div class="party-chip" draggable="true" data-party="' + p + '" style="border-color:' + PARTY_COLORS[p] + ';background:' + PARTY_COLORS[p] + '22;color:' + PARTY_COLORS[p] + '">' + p + '<span class="party-chip-votes">' + pct.toFixed(1) + '%</span></div>';
    });
    $('parties-pool').innerHTML = poolHtml;
    
    document.querySelectorAll('.party-chip[draggable="true"]').forEach(function(chip){
      chip.addEventListener('dragstart', function(e){
        e.dataTransfer.setData('party', chip.dataset.party);
        chip.classList.add('drag');
      });
      chip.addEventListener('dragend', function(){ chip.classList.remove('drag'); });
    });
    
    [1,2,3].forEach(function(b){
      let html = '';
      blocks[b].forEach(function(p){
        const c = PARTY_COLORS[p];
        html += '<div class="party-chip" data-party="' + p + '" data-from-block="' + b + '" draggable="true" style="border-color:' + c + ';background:' + c + '33;color:' + c + '">' + p + '<span style="margin-left:4px;cursor:pointer;color:#fff" data-remove="' + p + '" data-from="' + b + '">✕</span></div>';
      });
      $('b' + b + '-parties').innerHTML = html;
      
      let bv = 0;
      dataset.forEach(function(d){ bv += blockTotal(d, elecKey, blocks[b]); });
      const pct = totalVV > 0 ? bv/totalVV*100 : 0;
      $('b' + b + '-stats').textContent = fmt(bv) + ' votos · ' + pct.toFixed(2) + '%';
      $('b' + b + '-pct').textContent = pct.toFixed(1) + '%';
    });
    
    document.querySelectorAll('.party-chip[data-from-block]').forEach(function(chip){
      chip.addEventListener('dragstart', function(e){
        e.dataTransfer.setData('party', chip.dataset.party);
        e.dataTransfer.setData('from', chip.dataset.fromBlock);
        chip.classList.add('drag');
      });
      chip.addEventListener('dragend', function(){ chip.classList.remove('drag'); });
    });
    document.querySelectorAll('[data-remove]').forEach(function(x){
      x.addEventListener('click', function(e){
        e.stopPropagation();
        const p = x.dataset.remove;
        const from = parseInt(x.dataset.from);
        blocks[from] = blocks[from].filter(function(pp){return pp !== p;});
        renderAll();
      });
    });
  }

  function setupDropzones() {
    document.querySelectorAll('.block-zone').forEach(function(zone){
      zone.addEventListener('dragover', function(e){ e.preventDefault(); zone.classList.add('dragover'); });
      zone.addEventListener('dragleave', function(){ zone.classList.remove('dragover'); });
      zone.addEventListener('drop', function(e){
        e.preventDefault();
        zone.classList.remove('dragover');
        const party = e.dataTransfer.getData('party');
        const target = parseInt(zone.dataset.block);
        if (!party) return;
        [1,2,3].forEach(function(b){ blocks[b] = blocks[b].filter(function(p){return p !== party;}); });
        blocks[target].push(party);
        renderAll();
      });
    });
    $('parties-pool').addEventListener('dragover', function(e){ e.preventDefault(); });
    $('parties-pool').addEventListener('drop', function(e){
      e.preventDefault();
      const party = e.dataTransfer.getData('party');
      if (!party) return;
      [1,2,3].forEach(function(b){ blocks[b] = blocks[b].filter(function(p){return p !== party;}); });
      renderAll();
    });
  }

