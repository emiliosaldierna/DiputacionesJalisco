  // === GRÁFICA DE BARRAS COMPARATIVA FED VS LOCAL ===
  // 4 barras por distrito: 1° y 2° lugar en Federal + 1° y 2° en Local
  function renderCompareChart() {
    const fedKey = $('cc-fed-key') ? $('cc-fed-key').value : 'f24';
    const locKey = $('cc-loc-key') ? $('cc-loc-key').value : 'd24';
    const mode = $('cc-mode') ? $('cc-mode').value : 'bloques';
    
    const DF_OBJ = [3,4,6,7,9,10,11,12,13,14,16,20];
    
    // Para un distrito en una boleta: si mode='bloques' devuelve top2 bloques con voto, si mode='partidos' top2 partidos
    function getTop2(df, elecKey) {
      const pool = DATA.filter(function(d){return d[2] === df;});
      let totalVV = 0;
      pool.forEach(function(d){ const e = getElec(d, elecKey); if (e) totalVV += e.vv; });
      if (totalVV === 0) return [];
      
      let entries = [];
      if (mode === 'bloques') {
        [1,2,3].forEach(function(bid){
          if (blocks[bid].length === 0) return;
          let v = 0;
          pool.forEach(function(d){ v += blockTotal(d, elecKey, blocks[bid]); });
          entries.push({
            name: blockNames[bid],
            short: 'B' + bid,
            color: BLOCK_COLORS[bid-1],
            votes: v,
            pct: v/totalVV*100
          });
        });
      } else {
        PARTIES.forEach(function(p, idx){
          let v = 0;
          pool.forEach(function(d){ const e = getElec(d, elecKey); if (e) v += e.partidos[idx].solo; });
          if (v > 0) {
            entries.push({
              name: p,
              short: p,
              color: PARTY_COLORS[p],
              votes: v,
              pct: v/totalVV*100
            });
          }
        });
      }
      entries.sort(function(a,b){return b.votes - a.votes;});
      return entries.slice(0, 3); // top 3
    }
    
    const data = DF_OBJ.map(function(df){
      const fedTop = getTop2(df, fedKey);
      const locTop = getTop2(df, locKey);
      return { df: df, fedTop: fedTop, locTop: locTop };
    });
    
    // Ordenar por número de distrito
    data.sort(function(a,b){ return a.df - b.df; });
    
    const container = $('compare-chart');
    const W = container.clientWidth || 700;
    const rowH = 160;  // alto suficiente para 6 barras (3 fed + 3 loc) + headers + gap
    const PAD_L = 60, PAD_R = 30, PAD_T = 30, PAD_B = 30;
    const H = PAD_T + PAD_B + data.length * rowH;
    const innerW = W - PAD_L - PAD_R;
    
    // Escala 0-100% fija para que sea consistente
    const maxV = 100;
    const xAt = function(v){ return PAD_L + (v / maxV) * innerW; };
    
    let svg = '<svg viewBox="0 0 ' + W + ' ' + H + '" preserveAspectRatio="xMidYMid meet" style="width:100%;display:block">';
    
    // Grid vertical
    for (let i = 0; i <= 5; i++) {
      const v = (maxV / 5) * i;
      const x = xAt(v);
      svg += '<line x1="' + x + '" y1="' + PAD_T + '" x2="' + x + '" y2="' + (H-PAD_B) + '" class="cc-axis"/>';
      svg += '<text x="' + x + '" y="' + (PAD_T-8) + '" text-anchor="middle" class="cc-axis-text">' + v.toFixed(0) + '%</text>';
    }
    
    // Por cada distrito: 4 barras (FED 1°, FED 2°, LOC 1°, LOC 2°)
    data.forEach(function(d, i){
      const yTop = PAD_T + i * rowH + 6;
      const barH = 18;  // alto de cada barra
      const groupGap = 4;  // gap entre Fed y Loc
      
      // Línea separadora superior (excepto primera)
      if (i > 0) {
        svg += '<line x1="' + PAD_L + '" y1="' + (yTop - 2) + '" x2="' + (W-PAD_R) + '" y2="' + (yTop - 2) + '" stroke="rgba(140,180,240,0.1)" stroke-width="1"/>';
      }
      
      // Etiqueta distrito (D3, D4...)
      const winFed = DF_WIN[d.df] || DF_WIN[String(d.df)];
      const winLoc = DL_WIN[d.df] || DL_WIN[String(d.df)];
      svg += '<text x="' + (PAD_L-10) + '" y="' + (yTop + 14) + '" text-anchor="end" class="cc-label" style="font-weight:800;font-size:14px;fill:var(--gold)">D' + d.df + '</text>';
      // Etiqueta del ganador real
      if (winFed) {
        svg += '<text x="' + (PAD_L-10) + '" y="' + (yTop + 30) + '" text-anchor="end" class="cc-label" style="font-size:8px;fill:var(--text-tri)">Fed: ' + winFed.partido + '</text>';
      }
      if (winLoc) {
        svg += '<text x="' + (PAD_L-10) + '" y="' + (yTop + 42) + '" text-anchor="end" class="cc-label" style="font-size:8px;fill:var(--text-tri)">Loc: ' + winLoc.partido + '</text>';
      }
      
      // ===== BLOQUE FEDERAL =====
      svg += '<text x="' + PAD_L + '" y="' + yTop + '" class="cc-label" style="font-size:9px;font-weight:800;fill:var(--gold);letter-spacing:1px">🇲🇽 FEDERAL</text>';
      
      // Renderizar top 3 federal
      const RANK_LABELS = ['1°','2°','3°'];
