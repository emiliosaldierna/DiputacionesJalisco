  function getColor(d) {
    const elecKey = getCurrentElecKey();  // sincronizado con filtro principal
    if (!elecKey) return '#5a6b8a';
    
    // Modo PARTY:MODE - color del partido ganador en cada sección
    if (currentMapFilter === 'PARTY:MODE') {
      const e = getElec(d, elecKey);
      if (!e || e.vv === 0) return '#2a3548';
      let maxV = 0, winP = null;
      PARTIES.forEach(function(p, idx){
        if (e.partidos[idx].solo > maxV) {
          maxV = e.partidos[idx].solo;
          winP = p;
        }
      });
      return winP ? PARTY_COLORS[winP] : '#5a6b8a';
    }
    // Modo legacy con escala de intensidad por bloque/partido específico (no se usa actualmente)
    if (currentMapFilter !== 'auto' && currentLayer !== 'arrastre') {
      const e = getElec(d, elecKey);
      if (!e || e.vv === 0) return '#2a3548';
      let voto = 0, color = '#5a6b8a';
      if (currentMapFilter.indexOf('PARTY:') === 0) {
        const partyName = currentMapFilter.split(':')[1];
        const idx = PARTIES.indexOf(partyName);
        if (idx >= 0) {
          voto = e.partidos[idx].solo;
          color = PARTY_COLORS[partyName] || '#5a6b8a';
        }
      } else if (currentMapFilter === 'B1') { voto = blockTotal(d, elecKey, blocks[1]); color = BLOCK_COLORS[0]; }
      else if (currentMapFilter === 'B2') { voto = blockTotal(d, elecKey, blocks[2]); color = BLOCK_COLORS[1]; }
      else if (currentMapFilter === 'B3') { voto = blockTotal(d, elecKey, blocks[3]); color = BLOCK_COLORS[2]; }
      const pct = voto / e.vv * 100;
      const intensity = Math.min(1, pct / 60);
      const hex = color.replace('#', '');
      const r = parseInt(hex.substring(0,2), 16);
      const g = parseInt(hex.substring(2,4), 16);
      const b = parseInt(hex.substring(4,6), 16);
      const baseR = 42, baseG = 53, baseB = 72;
      const finalR = Math.round(baseR + (r - baseR) * intensity);
      const finalG = Math.round(baseG + (g - baseG) * intensity);
      const finalB = Math.round(baseB + (b - baseB) * intensity);
      return 'rgb(' + finalR + ',' + finalG + ',' + finalB + ')';
    }
    
    const b1 = blockTotal(d, elecKey, blocks[1]);
    const b2 = blockTotal(d, elecKey, blocks[2]);
    const b3 = blockTotal(d, elecKey, blocks[3]);
    const max = Math.max(b1, b2, b3);
    if (max === 0) return '#5a6b8a';
    if (max === b1) return BLOCK_COLORS[0];
    if (max === b2) return BLOCK_COLORS[1];
    return BLOCK_COLORS[2];
  }

