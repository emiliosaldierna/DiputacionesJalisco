<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard Electoral · Diputados Locales Jalisco</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --border:rgba(140,180,240,0.12);
  --text-pri:#e8f0ff; --text-sec:#8fa3c7; --text-tri:#5a6b8a;
  --gold:#ffb13b; --green:#2dffaa; --red:#ff2d4f; --cyan:#00f0ff; --purple:#b14eff;
  --b1:#e83030; --b2:#ff8c00; --b3:#2266cc;
}
body {
  font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
  background:linear-gradient(180deg,#050810 0%,#0a0e1a 50%,#050810 100%);
  background-attachment:fixed; color:var(--text-pri); min-height:100vh; padding:14px; font-size:13px;
}
.container{max-width:1400px;margin:0 auto;}
.header{background:linear-gradient(135deg,rgba(0,240,255,0.06),rgba(255,177,59,0.04));border:1px solid rgba(0,240,255,0.2);border-radius:10px;padding:16px 20px;margin-bottom:14px;position:relative;overflow:hidden;}
.header::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--cyan) 0%,var(--gold) 50%,var(--cyan) 100%);animation:scan 4s linear infinite;}
@keyframes scan{0%,100%{opacity:.4}50%{opacity:1}}
.header-row{display:flex;align-items:center;gap:12px;}
.header-icon{font-size:28px;filter:drop-shadow(0 0 12px var(--cyan));}
.header-title{font-size:18px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--gold);}
.header-sub{font-size:11px;color:var(--text-sec);margin-top:2px;}
.gf-panel{background:linear-gradient(135deg,rgba(255,177,59,0.08),rgba(0,240,255,0.04));border:1px solid rgba(255,177,59,0.3);border-radius:8px;padding:12px 16px;margin-bottom:14px;}
.gf-title{font-size:10px;color:var(--gold);letter-spacing:2px;text-transform:uppercase;font-weight:700;margin-bottom:8px;}
.gf-row{display:flex;gap:10px;align-items:end;flex-wrap:wrap;}
.gf-block{flex:1;min-width:180px;}
.gf-block label{font-size:9px;color:var(--text-tri);letter-spacing:1px;text-transform:uppercase;display:block;margin-bottom:4px;}
.gf-block select{width:100%;padding:8px 10px;background:rgba(5,8,16,0.8);border:1px solid rgba(255,177,59,0.3);border-radius:5px;color:var(--text-pri);font-size:13px;font-weight:700;font-family:inherit;cursor:pointer;}
.gf-block select:focus{outline:none;border-color:var(--gold);}
.panel{background:linear-gradient(180deg,rgba(15,21,37,0.85),rgba(10,14,26,0.9));border:1px solid var(--border);border-radius:8px;padding:14px 16px;margin-bottom:14px;}
.panel-header{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px;flex-wrap:wrap;gap:8px;}
.panel-title{font-size:12px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--cyan);}
.panel-sub{font-size:9px;color:var(--text-tri);letter-spacing:.5px;}
.block-builder{background:linear-gradient(135deg,rgba(177,78,255,0.08),rgba(0,240,255,0.04));border:1px solid rgba(177,78,255,0.3);border-radius:8px;padding:14px 16px;margin-bottom:14px;}
.bb-title{font-size:11px;color:var(--purple);letter-spacing:2px;text-transform:uppercase;font-weight:700;margin-bottom:4px;}
.bb-sub{font-size:10px;color:var(--text-sec);margin-bottom:12px;}
.parties-pool{display:flex;flex-wrap:wrap;gap:6px;padding:10px;background:rgba(5,8,16,0.5);border:1px dashed rgba(140,180,240,0.2);border-radius:6px;margin-bottom:12px;min-height:46px;}
.pool-label{width:100%;font-size:9px;color:var(--text-tri);letter-spacing:1px;text-transform:uppercase;margin-bottom:4px;}
.party-chip{padding:5px 10px;background:rgba(5,8,16,0.7);border:1px solid var(--text-tri);color:var(--text-pri);border-radius:4px;font-size:11px;font-weight:700;cursor:grab;transition:all .15s;user-select:none;display:inline-flex;align-items:center;gap:6px;}
.party-chip:hover{transform:scale(1.05);}
.party-chip.drag{opacity:.4;}
.party-chip .chip-remove{font-size:10px;cursor:pointer;color:var(--text-sec);}
.party-chip .chip-remove:hover{color:var(--red);}
.blocks-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.block-zone{border-radius:6px;padding:10px;min-height:80px;border:2px dashed transparent;transition:all .15s;}
.block-zone.b1{background:rgba(232,48,48,0.08);border-color:rgba(232,48,48,0.4);}
.block-zone.b2{background:rgba(255,140,0,0.08);border-color:rgba(255,140,0,0.4);}
.block-zone.b3{background:rgba(34,102,204,0.08);border-color:rgba(34,102,204,0.4);}
.block-zone.dragover{border-style:solid;transform:scale(1.02);}
.block-zone.b1.dragover{background:rgba(232,48,48,0.15);}
.block-zone.b2.dragover{background:rgba(255,140,0,0.15);}
.mini-builder{background:rgba(0,240,255,0.03);border:1px solid rgba(0,240,255,0.15);border-radius:6px;padding:10px;margin-bottom:10px;}
.mini-builder-title{font-size:9px;color:var(--cyan);letter-spacing:1.5px;text-transform:uppercase;font-weight:700;margin-bottom:6px;}
.block-zone.b4.dragover{background:rgba(0,180,150,0.15);}
.b4 .block-name{color:#00b496;}
.b4 .block-pct{color:#00b496;}
.party-indiv-card{flex:1;min-width:130px;max-width:200px;padding:12px 14px;background:rgba(5,8,16,0.7);border-radius:6px;border:2px solid transparent;position:relative;overflow:hidden;}
.party-indiv-card .rank{position:absolute;top:8px;right:10px;font-size:9px;color:var(--text-tri);font-weight:700;}
.party-indiv-card .p-name{font-size:11px;font-weight:800;letter-spacing:.5px;text-transform:uppercase;margin-bottom:4px;}
.party-indiv-card .p-pct{font-size:22px;font-weight:800;line-height:1;}
.party-indiv-card .p-votes{font-size:10px;color:var(--text-sec);margin-top:4px;}
.party-indiv-card .p-bar{height:3px;border-radius:2px;margin-top:8px;}
.block-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;}
.block-name{font-size:9px;letter-spacing:1px;text-transform:uppercase;font-weight:700;flex:1;background:transparent;border:none;font-family:inherit;outline:none;border-bottom:1px dotted transparent;padding:2px 4px;cursor:text;}
.block-name:hover,.block-name:focus{border-bottom-color:currentColor;}
.b1 .block-name{color:var(--b1);}.b2 .block-name{color:var(--b2);}.b3 .block-name{color:var(--b3);}
.block-stats{font-size:9px;color:var(--text-sec);text-align:right;}
.block-pct{font-size:14px;font-weight:800;}
.b1 .block-pct{color:var(--b1);}.b2 .block-pct{color:var(--b2);}.b3 .block-pct{color:var(--b3);}
.bb-actions{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;}
.bb-btn{padding:6px 12px;background:rgba(0,240,255,0.08);color:var(--cyan);border:1px solid rgba(0,240,255,0.3);border-radius:5px;cursor:pointer;font-family:inherit;font-size:10px;font-weight:700;letter-spacing:.5px;}
.bb-btn:hover{background:rgba(0,240,255,0.15);}
.bb-btn.preset{background:rgba(255,177,59,0.08);color:var(--gold);border-color:rgba(255,177,59,0.3);}
.bb-btn.preset:hover{background:rgba(255,177,59,0.15);}
.hist-toggle{display:flex;gap:8px;margin-bottom:10px;}
.hist-btn{padding:5px 12px;border-radius:4px;cursor:pointer;font-family:inherit;font-size:10px;font-weight:700;letter-spacing:.5px;border:1px solid rgba(255,177,59,.4);background:rgba(255,177,59,.05);color:var(--gold);transition:all .15s;}
.hist-btn.active{background:rgba(255,177,59,.2);}
.kpi-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px;}
.kpi-card{flex:1;min-width:110px;padding:10px 12px;background:rgba(5,8,16,.7);border-radius:6px;border:1px solid var(--border);text-align:center;}
.kpi-label{font-size:9px;color:var(--text-tri);letter-spacing:1px;text-transform:uppercase;margin-bottom:4px;}
.kpi-val{font-size:18px;font-weight:800;}
.kpi-sub{font-size:10px;color:var(--text-sec);margin-top:2px;}
.blocks-bar-wrap{margin-bottom:10px;}
.blocks-bar{height:28px;border-radius:5px;display:flex;overflow:hidden;margin-bottom:4px;border:1px solid var(--border);}
.bar-seg{height:100%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;transition:width .5s ease;white-space:nowrap;overflow:hidden;}
.bar-seg.b1{background:var(--b1);}.bar-seg.b2{background:var(--b2);color:#111;}.bar-seg.b3{background:var(--b3);}.bar-seg.bn{background:#2a3350;color:var(--text-sec);}
.blocks-legend{display:flex;gap:12px;flex-wrap:wrap;margin-top:4px;}
.leg-item{display:flex;align-items:center;gap:5px;font-size:10px;color:var(--text-sec);}
.leg-dot{width:10px;height:10px;border-radius:2px;}
.chart-wrap{position:relative;width:100%;height:260px;}
.scenarios-container{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
@media(max-width:900px){.scenarios-container,.blocks-grid{grid-template-columns:1fr;}}
.scen-card{background:rgba(15,21,37,0.7);border:1px solid var(--border);border-radius:8px;padding:12px;}
.scen-card-title{font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:10px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.scen-name{background:transparent;border:none;border-bottom:1px dotted;font-family:inherit;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;outline:none;flex:1;min-width:0;}
.scen-table{width:100%;border-collapse:collapse;font-size:11px;}
.scen-table th{background:rgba(5,8,16,0.6);color:var(--text-tri);font-size:9px;letter-spacing:1px;text-transform:uppercase;padding:5px 7px;text-align:left;border-bottom:1px solid var(--border);}
.scen-table td{padding:5px 7px;border-bottom:1px solid rgba(140,180,240,0.06);font-variant-numeric:tabular-nums;vertical-align:middle;}
.scen-table tr:last-child td{background:rgba(255,177,59,0.05);font-weight:700;}
.scen-table tr:hover td{background:rgba(0,240,255,0.03);}
.scen-table .win{font-weight:800;}
.party-indiv-card{
  flex:1;min-width:130px;max-width:200px;padding:12px 14px;
  background:rgba(5,8,16,0.7);border-radius:6px;border:2px solid transparent;
  position:relative;overflow:hidden;
}
.party-indiv-card .rank{
  position:absolute;top:8px;right:10px;font-size:9px;color:var(--text-tri);font-weight:700;
}
.party-indiv-card .p-name{font-size:11px;font-weight:800;letter-spacing:.5px;text-transform:uppercase;margin-bottom:4px;}
.party-indiv-card .p-pct{font-size:22px;font-weight:800;line-height:1;}
.party-indiv-card .p-votes{font-size:10px;color:var(--text-sec);margin-top:4px;}
.party-indiv-card .p-bar{height:3px;border-radius:2px;margin-top:8px;}
.sep-btn-row{display:flex;justify-content:center;margin:12px 0;}
.sep-btn{padding:8px 24px;background:rgba(177,78,255,0.1);color:var(--purple);border:1px solid rgba(177,78,255,0.4);border-radius:20px;cursor:pointer;font-family:inherit;font-size:11px;font-weight:700;letter-spacing:1px;transition:all .2s;}
.sep-btn:hover{background:rgba(177,78,255,0.2);}
.merged-result{margin-top:14px;padding:14px;background:rgba(177,78,255,0.06);border:1px solid rgba(177,78,255,0.3);border-radius:8px;display:none;overflow-x:auto;}
.merged-result.show{display:block;}
.merged-title{font-size:11px;color:var(--purple);font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:10px;}
.merged-table{width:100%;border-collapse:collapse;font-size:11px;min-width:800px;}
.merged-table th{background:rgba(177,78,255,0.1);color:var(--purple);font-size:9px;letter-spacing:1px;text-transform:uppercase;padding:5px 7px;text-align:left;border-bottom:1px solid rgba(177,78,255,0.2);}
.merged-table td{padding:5px 7px;border-bottom:1px solid rgba(140,180,240,0.06);font-variant-numeric:tabular-nums;vertical-align:middle;}
.merged-table .win{font-weight:800;}
</style>
</head>
<body>
<div class="container">

<div class="header">
  <div class="header-row">
    <span class="header-icon">🗳️</span>
    <div>
      <div class="header-title">Dashboard Electoral · Diputados Locales Jalisco</div>
      <div class="header-sub">2018 · 2021 · 2024 · Constructor de Bloques · Escenarios de Alianza</div>
    </div>
  </div>
</div>

<div class="gf-panel">
  <div class="gf-title">▶ Filtro Principal</div>
  <div class="gf-row">
    <div class="gf-block">
      <label>Año</label>
      <select id="filter-year">
        <option value="all">Todos los años</option>
        <option value="2018">2018</option>
        <option value="2021">2021</option>
        <option value="2024" selected>2024</option>
      </select>
    </div>
    <div class="gf-block">
      <label>Distrito</label>
      <select id="filter-district"><option value="all">Todos los 20 distritos</option></select>
    </div>
  </div>
</div>

<!-- ANÁLISIS POR PARTIDO INDIVIDUAL -->
<div class="panel" id="party-kpi-panel">
  <div style="margin-bottom:10px;">
    <div style="font-size:12px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--cyan);">Análisis por Partido Individual</div>
    <div style="font-size:9px;color:var(--text-tri);letter-spacing:.5px;margin-top:2px;">Voto exclusivo · Sigue filtros de año y distrito</div>
  </div>
  <div id="party-indiv-row" style="display:flex;flex-wrap:wrap;gap:8px;"></div>
</div>

<!-- CONSTRUCTOR PRINCIPAL -->
<div class="block-builder">
  <div class="bb-title">▶ Constructor de Bloques Principal · También define Tabla A</div>
  <div class="bb-sub">Arrastra los partidos. Afecta KPIs, gráfica histórica y la Tabla A de escenarios.</div>
  <div class="parties-pool" id="pool-a"><span class="pool-label">Partidos sin asignar</span></div>
  <div class="blocks-grid">
    <div class="block-zone b1" id="zone-1" data-zone="1"><div class="block-header"><input class="block-name" id="block-name-1" value="BLOQUE 1"><div class="block-stats"><div class="block-pct" id="block-pct-1">0%</div><div id="block-votes-1" style="font-size:9px;color:var(--text-sec)">0 votos</div></div></div></div>
    <div class="block-zone b2" id="zone-2" data-zone="2"><div class="block-header"><input class="block-name" id="block-name-2" value="BLOQUE 2"><div class="block-stats"><div class="block-pct" id="block-pct-2">0%</div><div id="block-votes-2" style="font-size:9px;color:var(--text-sec)">0 votos</div></div></div></div>
    <div class="block-zone b3" id="zone-3" data-zone="3"><div class="block-header"><input class="block-name" id="block-name-3" value="BLOQUE 3"><div class="block-stats"><div class="block-pct" id="block-pct-3">0%</div><div id="block-votes-3" style="font-size:9px;color:var(--text-sec)">0 votos</div></div></div></div>
  </div>
  <div class="bb-actions">
    <button class="bb-btn preset" onclick="applyPreset('4t')">4T vs MC vs Frente</button>
    <button class="bb-btn preset" onclick="applyPreset('solo')">MORENA vs MC vs PAN</button>
    <button class="bb-btn" onclick="clearBlocks()">⟳ Limpiar</button>
  </div>
</div>

<!-- HISTÓRICA -->
<div class="panel">
  <div class="panel-header">
    <div><div class="panel-title">Comparativa Histórica · 2018 · 2021 · 2024</div><div class="panel-sub">Sigue filtro de distrito · Barras agrupadas por año</div></div>
    <div class="hist-toggle">
      <button class="hist-btn active" id="hbtn-b" onclick="setHistMode('bloques')">Por Bloques</button>
      <button class="hist-btn" id="hbtn-p" onclick="setHistMode('partidos')">Por Partidos</button>
    </div>
  </div>
  <div id="kpi-b-sec"><div class="kpi-row" id="kpi-b-row"></div><div class="blocks-bar-wrap"><div class="blocks-bar" id="dist-bar"></div><div class="blocks-legend" id="dist-legend"></div></div></div>
  <div id="kpi-p-sec" style="display:none"><div class="kpi-row" id="kpi-p-row"></div></div>
  <div class="chart-wrap"><canvas id="hist-canvas"></canvas></div>
</div>

<!-- ESCENARIOS -->
<div class="panel">
  <div class="panel-header">
    <div><div class="panel-title">Comparativa de Escenarios</div><div class="panel-sub">Tabla A usa bloques del constructor principal · Tabla B tiene constructor independiente de 4 bloques</div></div>
  </div>

  <!-- TABLA POR PARTIDO (única, arriba) -->
  <div style="font-size:9px;color:var(--text-tri);letter-spacing:1px;text-transform:uppercase;margin-bottom:6px;">▸ Votos por Partido · Por Distrito</div>
  <div style="overflow-x:auto;margin-bottom:18px;">
    <table class="scen-table" id="party-table-main" style="min-width:600px;">
      <thead id="party-head-main"><tr><th>DTTO</th><th>GANADOR</th></tr></thead>
      <tbody></tbody>
    </table>
  </div>

  <div class="scenarios-container">
    <!-- TABLA A -->
    <div class="scen-card" style="border-color:rgba(177,78,255,0.35);">
      <div class="scen-card-title" style="color:var(--purple);">🅐 Tabla A <span style="font-size:9px;font-weight:400;color:var(--text-sec);">← usa bloques del constructor principal</span></div>
      <div id="scen-a-preview" style="display:flex;gap:5px;flex-wrap:wrap;margin-bottom:10px;min-height:24px;"></div>
      <table class="scen-table" id="scen-table-a">
        <thead id="scen-head-a"><tr><th>DTTO</th><th>B1</th><th>B2</th><th>B3</th><th>GANADOR</th></tr></thead>
        <tbody></tbody>
      </table>
    </div>

    <!-- TABLA B -->
    <div class="scen-card" style="border-color:rgba(0,240,255,0.35);">
      <div class="scen-card-title" style="color:var(--cyan);">🅑 <input class="scen-name" id="scen-name-b" value="Tabla B" style="color:var(--cyan);border-bottom-color:var(--cyan);"></div>
      <div class="mini-builder">
        <div class="mini-builder-title">Constructor de Bloques · Independiente · 4 bloques</div>
        <div class="parties-pool" id="pool-b" style="min-height:36px;margin-bottom:8px;"><span class="pool-label">Partidos sin asignar</span></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;" id="blocks-b-grid">
          <div class="block-zone b1" id="zone-b-1" data-zone="b1"><div class="block-header"><input class="block-name" id="block-b-name-1" value="BLOQUE B1"><div class="block-stats"><div class="block-pct" id="block-b-pct-1">0%</div><div id="block-b-votes-1" style="font-size:9px;color:var(--text-sec)">0 votos</div></div></div></div>
          <div class="block-zone b2" id="zone-b-2" data-zone="b2"><div class="block-header"><input class="block-name" id="block-b-name-2" value="BLOQUE B2"><div class="block-stats"><div class="block-pct" id="block-b-pct-2">0%</div><div id="block-b-votes-2" style="font-size:9px;color:var(--text-sec)">0 votos</div></div></div></div>
          <div class="block-zone b3" id="zone-b-3" data-zone="b3"><div class="block-header"><input class="block-name" id="block-b-name-3" value="BLOQUE B3"><div class="block-stats"><div class="block-pct" id="block-b-pct-3">0%</div><div id="block-b-votes-3" style="font-size:9px;color:var(--text-sec)">0 votos</div></div></div></div>
          <div class="block-zone b4" id="zone-b-4" data-zone="b4"><div class="block-header"><input class="block-name" id="block-b-name-4" value="BLOQUE B4"><div class="block-stats"><div class="block-pct" id="block-b-pct-4">0%</div><div id="block-b-votes-4" style="font-size:9px;color:var(--text-sec)">0 votos</div></div></div></div>
        </div>
        <div class="bb-actions" style="margin-top:8px;">
          <button class="bb-btn preset" onclick="applyPresetB('default')">MORENA+PT · MC+PVEM · PAN · PRI+PRD+HAG+FUT</button>
          <button class="bb-btn preset" onclick="applyPresetB('4t')">4T vs MC vs Frente</button>
          <button class="bb-btn" onclick="clearBlocksB()">⟳ Limpiar</button>
        </div>
      </div>
      <table class="scen-table" id="scen-table-b">
        <thead id="scen-head-b"><tr><th>DTTO</th><th>B1</th><th>B2</th><th>B3</th><th>B4</th><th>GANADOR</th></tr></thead>
        <tbody></tbody>
      </table>
    </div>
  </div>

  <div class="sep-btn-row">
    <button class="sep-btn" onclick="toggleMerge()" id="merge-btn">⊕ Comparar A vs B por Distrito</button>
  </div>
  <div class="merged-result" id="merged-result">
    <div class="merged-title">⚔ Comparativa A vs B · Ganadores por Distrito</div>
    <table class="merged-table" id="merged-table">
      <thead><tr>
        <th>DTTO</th>
        <th id="mha1">A-B1</th><th id="mha2">A-B2</th><th id="mha3">A-B3</th><th>GANADOR A</th>
        <th id="mhb1">B-B1</th><th id="mhb2">B-B2</th><th id="mhb3">B-B3</th><th id="mhb4">B-B4</th><th>GANADOR B</th>
        <th>¿COINCIDE?</th>
      </tr></thead>
