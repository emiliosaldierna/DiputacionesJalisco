// PARTY TABLE (única, arriba de escenarios) — ventaja de MORENA vs segundo
const sortStateParty={col:'dtto',dir:1};
function renderPartyTable(){
  const y=getY();const rows=y=='all'?D:D.filter(r=>r.y==+y);
  const pts=partiesFor(y=='all'?'all':+y);
  const ds=dList(y=='all'?null:+y);
  const headEl=document.getElementById('party-head-main');
  const tbody=document.querySelector('#party-table-main tbody');
  if(!headEl||!tbody)return;

  // Build rows with MORENA ventaja
  let rowData=ds.map(d=>{
    const dr=rows.filter(r=>r.d==d);const tot=dr.reduce((s,r)=>s+r.T,0);
    const pv={};pts.forEach(p=>{pv[p]=sumP(dr,p);});
    const morenaV=pv['MORENA']||0;
    const others=pts.filter(p=>p!=='MORENA').map(p=>pv[p]||0);
    const maxOther=others.length?Math.max(...others):0;
    const ventaja=morenaV-maxOther;
    const ventajaPct=tot?(ventaja/tot*100).toFixed(1):0;
    const mx=Math.max(...pts.map(p=>pv[p]));const winner=pts.find(p=>pv[p]===mx)||'';
    return{d,tot,pv,mx,winner,ventaja,ventajaPct};
  });

  // Sort
  const sp=sortStateParty;
  if(sp.col==='dtto') rowData.sort((a,b)=>sp.dir*(a.d-b.d));
  else if(sp.col==='ventaja') rowData.sort((a,b)=>sp.dir*(b.ventaja-a.ventaja));

  // Header
  const mkThP=(label,col)=>{
    const active=sp.col===col;const arrow=active?(sp.dir===1?'▲':'▼'):'⇅';
    return `<th style="cursor:pointer;user-select:none;${active?'color:var(--gold)':''}" onclick="toggleSortParty('${col}')">${label} <span style="font-size:8px;opacity:.7">${arrow}</span></th>`;
  };
  const htr=document.createElement('tr');
  htr.innerHTML=mkThP('DTTO','dtto');
  pts.forEach(p=>{const th=document.createElement('th');th.style.color=PC[p]||'#fff';th.textContent=PL[p]||p;htr.appendChild(th);});
  htr.innerHTML+=mkThP('VENTAJA MORENA','ventaja')+'<th>GANADOR</th>';
  headEl.innerHTML='';headEl.appendChild(htr);
  tbody.innerHTML='';

  const totals={};pts.forEach(p=>totals[p]=0);let totVentaja=0;
  rowData.forEach(({d,tot,pv,mx,winner,ventaja,ventajaPct})=>{
    pts.forEach(p=>totals[p]+=(pv[p]||0)); totVentaja+=ventaja;
    const row=document.createElement('tr');let c=`<td>${String(d).padStart(2,'0')}</td>`;
    pts.forEach(p=>{
      const v=pv[p]||0,pct=tot?(v/tot*100).toFixed(1):0,isW=p===winner;
      c+=`<td class="${isW?'win':''}" style="color:${isW?PC[p]:'var(--text-sec)'}">${fmt(v)}<br><span style="font-size:9px;opacity:.7">${pct}%</span></td>`;
    });
    const vColor=ventaja>=0?'var(--green)':'var(--red)';
    const vSign=ventaja>=0?'+':'';
    c+=`<td style="color:${vColor};font-weight:700">${vSign}${fmt(ventaja)}<br><span style="font-size:9px;opacity:.8">${vSign}${ventajaPct}%</span></td>`;
    c+=`<td style="color:${PC[winner]||'#fff'};font-weight:800">✅ ${PL[winner]||winner}</td>`;
    row.innerHTML=c;tbody.appendChild(row);
  });

  const gt=pts.reduce((s,p)=>s+totals[p],0);
  const mxT=Math.max(...pts.map(p=>totals[p]));const winT=pts.find(p=>totals[p]===mxT)||'';
  const trow=document.createElement('tr');let c=`<td>TOTAL</td>`;
  pts.forEach(p=>{const v=totals[p],pct=gt?(v/gt*100).toFixed(1):0;c+=`<td style="color:${PC[p]};font-weight:700">${fmt(v)}·${pct}%</td>`;});
  const tvColor=totVentaja>=0?'var(--green)':'var(--red)';
  c+=`<td style="color:${tvColor};font-weight:700">${totVentaja>=0?'+':''}${fmt(totVentaja)}</td>`;
  c+=`<td style="color:${PC[winT]||'#fff'};font-weight:800">✅ ${PL[winT]||winT}</td>`;
  trow.innerHTML=c;tbody.appendChild(trow);
}
