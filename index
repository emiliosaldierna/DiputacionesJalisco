['1','2','3'].forEach(b=>{
  document.getElementById('block-name-'+b).addEventListener('input',()=>{bNames[+b]=document.getElementById('block-name-'+b).value;refresh();renderCompChart();});
});
['1','2','3','4'].forEach(b=>{
