  // Header
  const headTr=document.querySelector('#scen-head-a tr');
  const mkTh=(label,col,side)=>{
    const active=sortState[side].col===col;
    const dir=sortState[side].dir;
    const arrow=active?(dir===1?'▲':'▼'):'⇅';
    return `<th style="cursor:pointer;user-select:none;${active?'color:var(--gold)':''}" onclick="toggleSort('${side}','${col}')">${label} <span style="font-size:8px;opacity:.7">${arrow}</span></th>`;
  };
  headTr.innerHTML=mkTh('DTTO','dtto','a');
  [1,2,3].forEach((b,i)=>{const nm=document.getElementById('block-name-'+b).value||'B'+b;headTr.innerHTML+=`<th style="color:${BC[i]}">${nm}</th>`;});
  headTr.innerHTML+=mkTh('VENTAJA MORENA','ventaja','a')+'<th>GANADOR</th>';

  const tbody=document.querySelector('#scen-table-a tbody');tbody.innerHTML='';
  let tots=[0,0,0],totVentaja=0;
  rowData.forEach(({d,tot,bv,mx,wi,ventaja,ventajaPct})=>{
    bv.forEach((v,i)=>tots[i]+=v); totVentaja+=ventaja;
    const tr=document.createElement('tr');let c=`<td>${String(d).padStart(2,'0')}</td>`;
    bv.forEach((v,i)=>{const p=tot?(v/tot*100).toFixed(1):0;c+=`<td class="${v===mx?'win':''}" style="${v===mx?'color:'+BC[i]:''}">${fmt(v)} <span style="font-size:9px;color:var(--text-tri)">${p}%</span></td>`;});
    const vColA=ventaja>=0?'var(--green)':'var(--red)';const vSignA=ventaja>=0?'+':'';
    c+=`<td style="color:${vColA};font-weight:700">${vSignA}${fmt(ventaja)}<br><span style="font-size:9px;opacity:.8">${vSignA}${ventajaPct}%</span></td>`;
    c+=`<td style="color:${BC[wi]};font-weight:800">✅ ${document.getElementById('block-name-'+(wi+1)).value||'B'+(wi+1)}</td>`;
    tr.innerHTML=c;tbody.appendChild(tr);
  });
  // totals row
  const tr=document.createElement('tr');let c=`<td>TOTAL</td>`;
  const gt=tots.reduce((s,v)=>s+v,0);
  tots.forEach((v,i)=>{const p=gt?(v/gt*100).toFixed(1):0;c+=`<td style="color:${BC[i]}">${fmt(v)}·${p}%</td>`;});
  const tvColA=totVentaja>=0?'var(--green)':'var(--red)';
  c+=`<td style="color:${tvColA}">${totVentaja>=0?'+':''}${fmt(totVentaja)}</td>`;
  const wi=tots.indexOf(Math.max(...tots));
  c+=`<td style="color:${BC[wi]};font-weight:800">✅ ${document.getElementById('block-name-'+(wi+1)).value||'B'+(wi+1)}</td>`;
  tr.innerHTML=c;tbody.appendChild(tr);
}

// TABLE B (4 bloques, sortable)
function renderTableB(){
  const y=getY();const rows=y=='all'?D:D.filter(r=>r.y==+y);
  const ds=dList(y=='all'?null:+y);

  // Build data rows — ventaja del bloque con MORENA vs segundo bloque
  let rowData=ds.map(d=>{
    const dr=rows.filter(r=>r.d==d);const tot=dr.reduce((s,r)=>s+r.T,0);
    const bv=[1,2,3,4].map(b=>sumB(dr,blocksB[b]||[]));
    const mx=Math.max(...bv),wi=bv.indexOf(mx);
    const morenaBlk=[1,2,3,4].findIndex(b=>(blocksB[b]||[]).includes('MORENA'));
    const morenaV=morenaBlk>=0?bv[morenaBlk]:0;
    const othersV=bv.filter((_,i)=>i!==morenaBlk);
    const maxOther=othersV.length?Math.max(...othersV):0;
    const ventaja=morenaV-maxOther;
    const ventajaPct=tot?(ventaja/tot*100).toFixed(1):0;
    return{d,tot,bv,mx,wi,ventaja,ventajaPct};
  });

  // Sort
  const s=sortState.b;
  if(s.col==='dtto') rowData.sort((a,b)=>s.dir*(a.d-b.d));
  else if(s.col==='ventaja') rowData.sort((a,b)=>s.dir*(b.ventaja-a.ventaja));

  // Header
  const headTr=document.querySelector('#scen-head-b tr');
  const mkTh=(label,col,side)=>{
    const active=sortState[side].col===col;
    const dir=sortState[side].dir;
    const arrow=active?(dir===1?'▲':'▼'):'⇅';
    return `<th style="cursor:pointer;user-select:none;${active?'color:var(--gold)':''}" onclick="toggleSort('${side}','${col}')">${label} <span style="font-size:8px;opacity:.7">${arrow}</span></th>`;
  };
  headTr.innerHTML=mkTh('DTTO','dtto','b');
  [1,2,3,4].forEach((b,i)=>{const nm=document.getElementById('block-b-name-'+b).value||'B'+b;headTr.innerHTML+=`<th style="color:${BC4[i]}">${nm}</th>`;});
  headTr.innerHTML+=mkTh('VENTAJA MORENA','ventaja','b')+'<th>GANADOR</th>';

  const tbody=document.querySelector('#scen-table-b tbody');tbody.innerHTML='';
  let tots=[0,0,0,0],totVentaja=0;
  rowData.forEach(({d,tot,bv,mx,wi,ventaja,ventajaPct})=>{
    bv.forEach((v,i)=>tots[i]+=v); totVentaja+=ventaja;
    const tr=document.createElement('tr');let c=`<td>${String(d).padStart(2,'0')}</td>`;
    bv.forEach((v,i)=>{const p=tot?(v/tot*100).toFixed(1):0;c+=`<td class="${v===mx?'win':''}" style="${v===mx?'color:'+BC4[i]:''}">${fmt(v)} <span style="font-size:9px;color:var(--text-tri)">${p}%</span></td>`;});
    const vColB=ventaja>=0?'var(--green)':'var(--red)';const vSignB=ventaja>=0?'+':'';
    c+=`<td style="color:${vColB};font-weight:700">${vSignB}${fmt(ventaja)}<br><span style="font-size:9px;opacity:.8">${vSignB}${ventajaPct}%</span></td>`;
    c+=`<td style="color:${BC4[wi]};font-weight:800">✅ ${document.getElementById('block-b-name-'+(wi+1)).value||'B'+(wi+1)}</td>`;
    tr.innerHTML=c;tbody.appendChild(tr);
  });
  const tr=document.createElement('tr');let c=`<td>TOTAL</td>`;
  const gt=tots.reduce((s,v)=>s+v,0);
  tots.forEach((v,i)=>{const p=gt?(v/gt*100).toFixed(1):0;c+=`<td style="color:${BC4[i]}">${fmt(v)}·${p}%</td>`;});
  const tvColB=totVentaja>=0?'var(--green)':'var(--red)';
  c+=`<td style="color:${tvColB}">${totVentaja>=0?'+':''}${fmt(totVentaja)}</td>`;
  const wi=tots.indexOf(Math.max(...tots));
  c+=`<td style="color:${BC4[wi]};font-weight:800">✅ ${document.getElementById('block-b-name-'+(wi+1)).value||'B'+(wi+1)}</td>`;
  tr.innerHTML=c;tbody.appendChild(tr);
}

function toggleSort(side,col){
  if(sortState[side].col===col) sortState[side].dir*=-1;
  else{sortState[side].col=col;sortState[side].dir=-1;}// default ventaja desc
  if(side==='a')renderTableA();else renderTableB();
}

// MERGE (A=3 vs B=4)
function toggleMerge(){
  mergeVisible=!mergeVisible;
  document.getElementById('merged-result').classList.toggle('show',mergeVisible);
  document.getElementById('merge-btn').textContent=mergeVisible?'⊖ Ocultar Comparativa':'⊕ Comparar A vs B por Distrito';
  if(mergeVisible)renderMerged();
}
function renderMerged(){
  [1,2,3].forEach(b=>{const h=document.getElementById('mha'+b);if(h)h.textContent=document.getElementById('block-name-'+b).value||'A'+b;});
  [1,2,3,4].forEach(b=>{const h=document.getElementById('mhb'+b);if(h)h.textContent=document.getElementById('block-b-name-'+b).value||'B'+b;});
  const y=getY();const rows=y=='all'?D:D.filter(r=>r.y==+y);
  const ds=dList(y=='all'?null:+y);
  const tbody=document.querySelector('#merged-table tbody');tbody.innerHTML='';
  let same=0,diff=0;
  ds.forEach(d=>{
    const dr=rows.filter(r=>r.d==d);const tot=dr.reduce((s,r)=>s+r.T,0);
    const av=[1,2,3].map(b=>sumB(dr,blocks[b]));
    const bv=[1,2,3,4].map(b=>sumB(dr,blocksB[b]||[]));
    const wA=av.indexOf(Math.max(...av)),wB=bv.indexOf(Math.max(...bv));
    const nmA=document.getElementById('block-name-'+(wA+1)).value||'A'+(wA+1);
    const nmB=document.getElementById('block-b-name-'+(wB+1)).value||'B'+(wB+1);
    const ok=(wA===wB);if(ok)same++;else diff++;
    const tr=document.createElement('tr');let c=`<td>${String(d).padStart(2,'0')}</td>`;
    av.forEach((v,i)=>{const p=tot?(v/tot*100).toFixed(1):0;c+=`<td class="${i===wA?'win':''}" style="${i===wA?'color:'+BC[i]:''}">${fmt(v)}<br><span style="font-size:9px;color:var(--text-tri)">${p}%</span></td>`;});
    c+=`<td style="color:${BC[wA]};font-weight:800">${nmA}</td>`;
    bv.forEach((v,i)=>{const p=tot?(v/tot*100).toFixed(1):0;c+=`<td class="${i===wB?'win':''}" style="${i===wB?'color:'+BC4[i]:''}">${fmt(v)}<br><span style="font-size:9px;color:var(--text-tri)">${p}%</span></td>`;});
    c+=`<td style="color:${BC4[wB]};font-weight:800">${nmB}</td>`;
    c+=`<td style="font-weight:800;color:${ok?'var(--green)':'var(--red)'}">${ok?'🟢 Igual':'🔴 Distinto'}</td>`;
    tr.innerHTML=c;tbody.appendChild(tr);
  });
  const tr=document.createElement('tr');tr.style.background='rgba(255,177,59,0.05)';
  tr.innerHTML=`<td colspan="11" style="font-weight:700;color:var(--gold);text-align:center;padding:8px">Mismo ganador: <span style="color:var(--green)">${same}</span> distritos · Ganador diferente: <span style="color:var(--red)">${diff}</span> distritos</td>`;
  tbody.appendChild(tr);
}

